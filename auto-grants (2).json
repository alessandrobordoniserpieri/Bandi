}

function exportMatchesCsv() {
  if (!lastMatchRows.length) { toast("Genera prima un matching"); return; }
  const rows = [[
    "cliente","bando","punteggio","decisione","prontezza_documentale","stato_bando","scadenza","territorio_bando","ente_erogatore",
    "temi","forma","territorio","capacita","partner","documenti","storico","scadenza_score",
    "azioni_consigliate","motivi_favorevoli","criticita"
  ]];
  lastMatchRows.forEach(m => {
    const parts = Object.fromEntries((m.breakdown || []).map(part => [part.label, `${part.value}/${part.max} - ${part.note}`]));
    rows.push([
      m.client.name,
      m.grant.title,
      m.score,
      matchDecisionLabel(m),
      `${clientDocumentProfile(m.client, m.grant).score}%`,
      normalizedGrantStatus(m.grant),
      deadlineLabel(m.grant.deadline),
      m.grant.area || "",
      m.grant.provider || "",
      parts.Temi || "",
      parts.Forma || "",
      parts.Territorio || "",
      parts["Capacità"] || "",
      parts.Partner || "",
      parts.Documenti || "",
      parts.Storico || "",
      parts.Scadenza || "",
      (m.actions || []).join("; "),
      m.plus.join("; "),
      m.minus.join("; ")
    ]);
  });
  const csv = rows.map(r => r.map(v => `"${String(v).replaceAll('"','""')}"`).join(",")).join("\n");
  const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `bandi-scanner-matching-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(a.href);
  toast("CSV esportato");
}

function mergeDefaultSources() {
  const existing = new Set(data.sources.map(s => s.name));
  DEFAULT_SOURCES.forEach(source => {
    if (!existing.has(source.name)) data.sources.push(normalizeSource(source));
  });
}

function mergeBundledAutoGrants() {
  if (!Array.isArray(BUNDLED_AUTO_GRANTS) || !BUNDLED_AUTO_GRANTS.length) return 0;
  let added = 0;
  BUNDLED_AUTO_GRANTS.forEach(grant => {
    const source = data.sources.find(s => s.name === grant.provider) || data.sources[0];
    if (upsertAutoGrant({ ...grant, text: `${grant.summary || ""} ${grant.requirements || ""} ${grant.detail || ""}` }, source)) added += 1;
  });
  if (added) {
    data.autoScan = {
      lastRun: new Date().toISOString(),
      lastCount: added,
      lastError: "Archivio locale incorporato nella pagina"
    };
  }
  return added;
}

function startAutoRadar() {
  renderAutoStatus("Radar automatico attivo. Controllo fonti in preparazione...");
  autoUpdateGrants();
  setInterval(() => autoUpdateGrants(), AUTO_SCAN_INTERVAL_MS);
}

function shouldRunAutoScan() {
  if (!data.autoScan?.lastRun) return true;
  const hours = (Date.now() - new Date(data.autoScan.lastRun).getTime()) / 36e5;
  return hours >= SOURCE_REFRESH_HOURS;
}

async function autoUpdateGrants() {
  const sources = data.sources.filter(s => s.url && s.frequency === "Automatico");
  if (!sources.length) return;
  renderAutoStatus(`Radar automatico: sto controllando ${sources.length} fonti pubbliche e private...`);
  let added = 0;
  const errors = [];

  const backendResult = await fetchBackendAutoGrants();
  if (backendResult) {
    backendResult.grants.forEach(grant => {
      const source = data.sources.find(s => s.name === grant.provider) || data.sources[0];
      if (upsertAutoGrant({ ...grant, text: `${grant.summary || ""} ${grant.requirements || ""} ${grant.detail || ""}` }, source)) added += 1;
    });
    data.autoScan = {
      lastRun: new Date().toISOString(),
      lastCount: added,
      lastError: backendResult.errors?.slice(0, 3).join(" | ") || ""
    };
    saveData();
    renderAutoStatus(`Radar automatico completato dal motore locale. Nuovi bandi aggiunti: ${added}. Fonti controllate: ${backendResult.sourcesChecked}.`);
    return;
  }

  const scans = await Promise.allSettled(sources.map(async source => {
    const html = await fetchSourceHtml(source.url);
    return { source, candidates: extractGrantCandidates(html, source).slice(0, 12) };
  }));

  scans.forEach((result, index) => {
    const source = sources[index];
    if (result.status === "rejected") {
      errors.push(`${source.name}: ${result.reason?.name === "AbortError" ? "tempo scaduto" : result.reason?.message || "non raggiungibile"}`);
      return;
    }
    result.value.candidates.forEach(candidate => {
      if (upsertAutoGrant(candidate, source)) added += 1;
    });
    source.lastCheck = new Date().toISOString().slice(0, 10);
    source.updatedAt = new Date().toISOString();
  });

  data.autoScan = {
    lastRun: new Date().toISOString(),
    lastCount: added,
    lastError: errors.slice(0, 3).join(" | ")
  };
  saveData();
  renderAutoStatus(`Radar automatico completato. Nuovi bandi aggiunti: ${added}. Fonti controllate: ${sources.length}.`);
}

async function fetchBackendAutoGrants() {
  if (!location.protocol.startsWith("http")) return null;
  try {
    const response = await fetch("/api/auto-grants", { cache: "no-store" });
    if (!response.ok) return null;
    return response.json();
  } catch {
    try {
      const snapshot = await fetch("data/auto-grants.json", { cache: "no-store" });
      if (!snapshot.ok) return null;
      return snapshot.json();
    } catch {
      return null;
    }
  }
}

function scheduleBackendSync() {
  if (!location.protocol.startsWith("http")) return;
  clearTimeout(syncTimer);
  syncTimer = setTimeout(syncDatabaseToBackend, 1200);
}

async function hydrateBackendDatabase() {
  if (!location.protocol.startsWith("http")) return;
  try {
    const response = await fetch("/api/database", { cache: "no-store" });
    if (!response.ok) return;
    const remote = await response.json();
    if (mergeBackendDatabase(remote)) {
      saveData();
      toast("Database locale sincronizzato con il motore");
    } else {
      scheduleBackendSync();
    }
  } catch {
    scheduleBackendSync();
  }
}

async function syncDatabaseToBackend() {
  if (!location.protocol.startsWith("http")) return;
  try {
    await fetch("/api/database", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(data)
    });
  } catch {
    // La versione Lite/offline continua a usare localStorage.
  }
}

function mergeBackendDatabase(remote) {
  if (!remote || typeof remote !== "object") return false;
  const hasRemoteData = (remote.clients || []).length || (remote.grants || []).length || (remote.sources || []).length || (remote.matchHistory || []).length;
  if (!hasRemoteData) return false;
  const before = JSON.stringify({
    clients: data.clients.map(c => c.id),
    grants: data.grants.map(g => g.id),
    sources: data.sources.map(s => s.id),
    history: (data.matchHistory || []).map(m => m.id)
  });
  data.clients = mergeEntities(data.clients, remote.clients || [], normalizeClient, item => item.id || normalizeKey(item.name));
  data.grants = mergeEntities(data.grants, remote.grants || [], normalizeGrant, item => item.url || item.id || normalizeKey(item.title));
  data.sources = mergeEntities(data.sources, remote.sources || [], normalizeSource, item => item.url || item.id || normalizeKey(item.name));
  data.matchHistory = mergeEntities(data.matchHistory || [], remote.matchHistory || [], normalizeMatchHistory, item => `${item.clientId}|${item.grantId}`).slice(0, 500);
  return before !== JSON.stringify({
    clients: data.clients.map(c => c.id),
    grants: data.grants.map(g => g.id),
    sources: data.sources.map(s => s.id),
    history: (data.matchHistory || []).map(m => m.id)
  });
}

function mergeEntities(localItems, remoteItems, normalizer, keyFn) {
  const map = new Map();
  [...localItems, ...remoteItems].forEach(item => {
    const normalized = normalizer(item);
    const key = keyFn(normalized);
    const itemTime = new Date(item.updatedAt || item.createdAt || item.savedAt || 0).getTime() || 0;
    const current = map.get(key);
    if (!current || itemTime >= current.time) map.set(key, { value: normalized, time: itemTime });
  });
  return [...map.values()].map(entry => entry.value);
}

async function fetchSourceHtml(url) {
  const proxied = `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`;
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 8000);
  const response = await fetch(proxied, { cache: "no-store", signal: controller.signal });
  clearTimeout(timer);
  if (!response.ok) throw new Error(`HTTP ${response.status}`);
  return response.text();
}

function extractGrantCandidates(html, source) {
  const doc = new DOMParser().parseFromString(html, "text/html");
  const base = source.url;
  const items = [];
  const pageTitle = cleanText(doc.querySelector("title")?.textContent || source.name);
  const pageText = cleanText(doc.body?.innerText || "");
  if (candidateRelevance(`${pageTitle} ${pageText.slice(0, 1200)}`) >= 5) {
    items.push({ title: pageTitle, url: base, text: pageText.slice(0, 1800) });
  }

  doc.querySelectorAll("a").forEach(a => {
    const title = cleanText(a.textContent || a.getAttribute("title") || "");
    if (title.length < 8 || title.length > 180) return;
    const href = a.getAttribute("href");
    if (!href || href.startsWith("#") || href.startsWith("mailto:") || href.startsWith("tel:")) return;
    const url = new URL(href, base).href;
    const localText = cleanText(`${title} ${a.closest("article, li, div, section")?.textContent || ""}`).slice(0, 1600);
    if (candidateRelevance(localText) >= 3) items.push({ title, url, text: localText });
  });

  const seen = new Set();
  return items
    .map(item => ({ ...item, title: normalizeCandidateTitle(item.title, source) }))
    .filter(item => item.title && !seen.has(item.url) && seen.add(item.url))
    .sort((a, b) => candidateRelevance(b.text) - candidateRelevance(a.text));
}

function candidateRelevance(text) {
  const hay = text.toLowerCase();
  const grantSignals = ["bando","avviso","call","contribut","finanziament","grant","fondo","sostegno","agevolaz","domanda","scadenza","manifestazione di interesse","voucher","incentiv","erogazion"];
  const targetSignals = ["sport","sociale","terzo settore","non profit","nonprofit","ets","aps","odv","asd","ssd","eps","volontariato","inclusione","welfare","giovani","disabilità","fondazione","associazione","cooperativa sociale","impresa sociale"];
  return grantSignals.filter(k => hay.includes(k)).length * 2 + targetSignals.filter(k => hay.includes(k)).length;
}

function upsertAutoGrant(candidate, source) {
  const existing = data.grants.find(g => (candidate.url && g.url === candidate.url) || normalizeKey(g.title) === normalizeKey(candidate.title));
  const inferred = inferGrantFromText(candidate, source);
  if (existing) {
    Object.assign(existing, {
      status: existing.status === "Chiuso" ? existing.status : inferred.status,
      deadline: existing.deadline || inferred.deadline,
      amount: existing.amount || inferred.amount,
      cofunding: existing.cofunding || inferred.cofunding,
      beneficiaries: chooseBetterText(existing.beneficiaries, inferred.beneficiaries),
      expenses: chooseBetterText(existing.expenses, inferred.expenses),
      detail: chooseBetterText(existing.detail, inferred.detail),
      tags: [...new Set([...(existing.tags || []), ...inferred.tags])],
      eligibleTypes: [...new Set([...(existing.eligibleTypes || []), ...inferred.eligibleTypes])],
      summary: chooseBetterText(existing.summary, inferred.summary),
      requirements: chooseBetterText(existing.requirements, inferred.requirements),
      updatedAt: new Date().toISOString()
    });
    return false;
  }
  data.grants.unshift(normalizeGrant({
    title: inferred.title,
    provider: source.name,
    sourceId: source.id,
    url: candidate.url,
    status: inferred.status,
    deadline: inferred.deadline,
    area: inferred.area,
    geoScope: inferred.geoScope,
    amount: inferred.amount,
    cofunding: inferred.cofunding,
    eligibleTypes: inferred.eligibleTypes,
    tags: inferred.tags,
    minCapacity: inferred.minCapacity,
    complexity: inferred.complexity,
    requirements: inferred.requirements,
    expenses: inferred.expenses,
    summary: inferred.summary,
    beneficiaries: inferred.beneficiaries,
    detail: inferred.detail,
    notes: "Importato automaticamente dal radar online. Verificare il testo ufficiale prima della candidatura.",
    importMode: "automatico",
    discoveredAt: new Date().toISOString()
  }));
  return true;
}

function chooseBetterText(current = "", next = "") {
  if (!next) return current || "";
  if (!current) return next;
  return next.length > current.length * 1.25 ? next : current;
}

function inferGrantFromText(candidate, source) {
  const text = cleanText(`${candidate.title} ${candidate.text}`);
  const lower = text.toLowerCase();
  const deadline = inferDeadline(text);
  const tags = TAGS.filter(tag => lower.includes(tag));
  if (lower.includes("sportiv") && !tags.includes("sport")) tags.push("sport");
  if (lower.includes("terzo settore") && !tags.includes("terzo settore")) tags.push("terzo settore");
  if (lower.includes("povertà educativa") && !tags.includes("povertà educativa")) tags.push("povertà educativa");

  const eligibleTypes = LEGAL_TYPES.filter(type => new RegExp(`\\b${type.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\b`, "i").test(text));
  if (lower.includes("associazioni sportive dilettantistiche") && !eligibleTypes.includes("ASD")) eligibleTypes.push("ASD");
  if (lower.includes("società sportive dilettantistiche") && !eligibleTypes.includes("SSD")) eligibleTypes.push("SSD");
  if ((lower.includes("ssd arl") || lower.includes("ssd a r.l")) && !eligibleTypes.includes("SSD a r.l.")) eligibleTypes.push("SSD a r.l.");
  if (lower.includes("enti di promozione sportiva") && !eligibleTypes.includes("EPS")) eligibleTypes.push("EPS");
  if (lower.includes("federazioni sportive nazionali") && !eligibleTypes.includes("FSN")) eligibleTypes.push("FSN");
  if (lower.includes("discipline sportive associate") && !eligibleTypes.includes("DSA")) eligibleTypes.push("DSA");
  if (lower.includes("enti del terzo settore") && !eligibleTypes.includes("ETS")) eligibleTypes.push("ETS");

  return {
    title: candidate.title,
    status: inferStatus(lower, deadline),
    deadline,
    area: inferArea(text, source),
    geoScope: inferGeoScope(text, source),
    amount: inferAmount(text),
    cofunding: inferCofunding(text),
    eligibleTypes,
    tags: tags.length ? [...new Set(tags)] : ["terzo settore"],
    minCapacity: lower.includes("partenariat") || lower.includes("nazionale") || lower.includes("europe") ? "Alta" : "Media",
    complexity: lower.includes("europe") || lower.includes("pnrr") || lower.includes("partenariat") ? "Alta" : "Media",
    beneficiaries: candidate.beneficiaries || extractBestSentences(text, ["beneficiari","destinatari","possono partecipare","ammessi","richiedenti","asd","ssd","aps","ets","odv"], 3),
    expenses: candidate.expenses || extractBestSentences(text, ["spese","ammissibili","attività finanziate","interventi","costi","realizzazione"], 3),
    detail: candidate.detail || extractBestSentences(text, ["scadenza","domande","dotazione","risorse","contributo","cofinanziamento","presentazione"], 4),
    requirements: candidate.requirements || extractBestSentences(text, ["requisiti","possono","ammessi","domanda","iscritti","runts","rasd","partenariato"], 4) || text.slice(0, 520),
    summary: candidate.summary || extractBestSentences(text, ["obiettivo","finalità","sostiene","finanzia","contributo","progetti","iniziative"], 3) || text.slice(0, 260)
  };
}

function extractBestSentences(text, keywords, limit) {
  return cleanText(text)
    .split(/(?<=[.!?])\s+/)
    .map(sentence => ({ sentence, score: keywords.filter(k => sentence.toLowerCase().includes(k)).length }))
    .filter(item => item.score > 0 && item.sentence.length > 30)
    .sort((a, b) => b.score - a.score)
    .slice(0, limit)
    .map(item => item.sentence)
    .join(" ");
}

function inferStatus(lower, deadline = "") {
  if (deadline && deadlineDays(deadline) < 0) return "Chiuso";
  if (lower.includes("in uscita")) return "In uscita";
  if (lower.includes("ricorrente")) return "Ricorrente";
  if (lower.includes("aperto") || lower.includes("domande") || lower.includes("scadenza")) return "Aperto";
  if (lower.includes("chiuso") || lower.includes("scaduto")) return "Chiuso";
  if (deadline) return "Aperto";
  return "Da verificare";
}

function inferDeadline(text) {
  const dates = extractCandidateDates(text);
  if (!dates.length) return "";
  const now = new Date();
  dates.sort((a, b) => b.score - a.score || Number(b.future) - Number(a.future) || Math.abs(a.time - now) - Math.abs(b.time - now));
  return dates[0].iso;
}

function extractCandidateDates(text = "") {
  const months = { gennaio:"01", febbraio:"02", marzo:"03", aprile:"04", maggio:"05", giugno:"06", luglio:"07", agosto:"08", settembre:"09", ottobre:"10", novembre:"11", dicembre:"12" };
  const dates = [];
  const push = (day, month, year, index) => {
    const d = Number(day);
    const m = Number(month);
    const y = Number(year);
    if (d < 1 || d > 31 || m < 1 || m > 12 || y < 2020 || y > 2035) return;
    const iso = `${y}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
    const time = new Date(iso + "T12:00:00").getTime();
    if (!Number.isFinite(time)) return;
    const context = text.slice(Math.max(0, index - 110), index + 160).toLowerCase();
    const positive = ["scadenza","scade","entro","presentazione","domanda","domande","candidatura","chiusura","termine","deadline","ore"].filter(k => context.includes(k)).length;
    const negative = ["pubblicato","avviso del","graduatoria","approvato","rendicontazione","evento","edizione","notizia"].filter(k => context.includes(k)).length;
    const future = time >= new Date().setHours(0,0,0,0);
    const score = positive * 8 + (future ? 5 : -3) - negative * 5;
    dates.push({ iso, time, future, score });
  };
  for (const match of text.matchAll(/\b([0-3]?\d)[/. -]([01]?\d)[/. -](20\d{2})\b/g)) push(match[1], match[2], match[3], match.index || 0);
  for (const match of text.toLowerCase().matchAll(/\b([0-3]?\d)\s+(gennaio|febbraio|marzo|aprile|maggio|giugno|luglio|agosto|settembre|ottobre|novembre|dicembre)\s+(20\d{2})\b/g)) push(match[1], months[match[2]], match[3], match.index || 0);
  return dates;
}

function inferArea(text, source) {
  const lower = `${text} ${source.name}`.toLowerCase();
  const areas = ["Emilia-Romagna","Lombardia","Piemonte","Liguria","Valle d'Aosta","Veneto","Friuli-Venezia Giulia","Toscana","Lazio","Marche","Umbria","Abruzzo","Molise","Campania","Puglia","Basilicata","Calabria","Sicilia","Sardegna","Trentino-Alto Adige"];
  return areas.find(a => lower.includes(a.toLowerCase())) || (lower.includes("europe") ? "Europa" : "Italia");
}

function inferGeoScope(text, source) {
  const lower = `${text} ${source.type} ${source.name}`.toLowerCase();
  if (lower.includes("europe")) return "Europeo";
  if (source.type.includes("regionale") || /emilia|lombardia|piemonte|liguria|veneto|toscana|lazio|puglia|sicilia|sardegna/.test(lower)) return "Regionale";
  if (lower.includes("comune") || lower.includes("comunale")) return "Comunale";
  return "Nazionale";
}

function inferAmount(text) {
  const match = text.match(/(?:€|euro)\s?([0-9][0-9.\s]{2,})/i) || text.match(/([0-9][0-9.\s]{2,})\s?(?:€|euro)/i);
  return match ? match[1].replace(/\s/g, "") : "";
}

function inferCofunding(text) {
  const match = text.match(/cofinanziamento[^0-9%]{0,40}([0-9]{1,2}\s?%)/i);
  return match ? match[1].replace(/\s/g, "") : "";
}

function normalizeCandidateTitle(title, source) {
  const clean = cleanText(title).replace(/^(leggi|scopri|vai|apri|download)\s+/i, "");
  if (/^(home|homepage|notizie|bandi|avvisi|contatti|privacy)$/i.test(clean)) return "";
  return clean || source.name;
}

function cleanText(value) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function normalizeKey(value) {
  return cleanText(value).toLowerCase().replace(/[^a-z0-9àèéìòù]/g, "");
}

function bindEvents() {
  document.querySelectorAll(".tab").forEach(b => b.onclick = () => switchView(b.dataset.view));
  ["clientSearch","grantSearch","sourceSearch"].forEach(id => $(id).oninput = renderAll);
  $("c_priority").oninput = () => $("priorityOut").textContent = $("c_priority").value;
  $("c_fileUpload").onchange = e => handleClientDocumentUpload(e.target.files);
  $("applyDocInsightsBtn").onclick = applyDocumentSuggestionsToClientForm;
  $("openRasdRegistryBtn").onclick = openRasdRegistry;
  $("runRasdComparisonBtn").onclick = () => runRasdComparison();
  $("clearClientDocsBtn").onclick = () => {
    clientDocs = [];
    $("c_fileUpload").value = "";
    renderClientDocuments();
    renderRasdCheckPanel(getClientForm());
    toast("Documenti rimossi dal profilo in modifica");
  };

  $("newClientBtn").onclick = () => setClientForm(null);
  $("clearClientBtn").onclick = () => setClientForm(null);
  $("seedClientBtn").onclick = () => setClientForm(normalizeClient(SAMPLE_CLIENT));
  $("saveClientBtn").onclick = () => {
    const c = getClientForm();
    if (!c.name) return toast("Inserisci almeno il nome del cliente");
    const i = data.clients.findIndex(x => x.id === c.id);
    i >= 0 ? data.clients[i] = c : data.clients.unshift(c);
    selectedClientId = c.id;
    saveData();
    setClientForm(c);
    toast("Cliente salvato");
  };
  $("deleteClientBtn").onclick = () => {
    if (!selectedClientId) return toast("Nessun cliente selezionato");
    if (confirm("Eliminare questo cliente?")) {
      data.clients = data.clients.filter(c => c.id !== selectedClientId);
      setClientForm(null);
      saveData();
      toast("Cliente eliminato");
    }
  };

  $("newGrantBtn").onclick = () => setGrantForm(null);
  $("clearGrantBtn").onclick = () => setGrantForm(null);
  $("seedGrantBtn").onclick = () => {
    const existing = new Set(data.grants.map(g => g.title));
    SAMPLE_GRANTS.filter(g => !existing.has(g.title)).forEach(g => data.grants.unshift(normalizeGrant(g)));
    saveData();
    toast("Bandi esempio aggiunti");
  };
  $("saveGrantBtn").onclick = () => {
    const g = getGrantForm();
    if (!g.title) return toast("Inserisci almeno il titolo del bando");
    const i = data.grants.findIndex(x => x.id === g.id);
    i >= 0 ? data.grants[i] = g : data.grants.unshift(g);
    selectedGrantId = g.id;
    saveData();
    setGrantForm(g);
    toast("Bando salvato");
  };
  $("deleteGrantBtn").onclick = () => {
    if (!selectedGrantId) return toast("Nessun bando selezionato");
    if (confirm("Eliminare questo bando?")) {
      data.grants = data.grants.filter(g => g.id !== selectedGrantId);
      setGrantForm(null);
      saveData();
      toast("Bando eliminato");
    }
  };

  $("newSourceBtn").onclick = () => setSourceForm(null);
  $("clearSourceBtn").onclick = () => setSourceForm(null);
  $("seedSourcesBtn").onclick = () => {
    const existing = new Set(data.sources.map(s => s.name));
    DEFAULT_SOURCES.filter(s => !existing.has(s.name)).forEach(s => data.sources.push(normalizeSource(s)));
    saveData();
    toast("Fonti base aggiornate");
  };
  $("saveSourceBtn").onclick = () => {
    const s = getSourceForm();
    if (!s.name) return toast("Inserisci almeno il nome della fonte");
    const i = data.sources.findIndex(x => x.id === s.id);
    i >= 0 ? data.sources[i] = s : data.sources.unshift(s);
    selectedSourceId = s.id;
    saveData();
    setSourceForm(s);
    toast("Fonte salvata");
  };
  $("deleteSourceBtn").onclick = () => {
    if (!selectedSourceId) return toast("Nessuna fonte selezionata");
    if (confirm("Eliminare questa fonte?")) {
      data.sources = data.sources.filter(s => s.id !== selectedSourceId);
      setSourceForm(null);
      saveData();
      toast("Fonte eliminata");
    }
  };

  $("matchClientSearch").oninput = renderMatchPickers;
  $("matchGrantSearch").oninput = renderMatchPickers;
  $("matchClient").onchange = () => $("matchClient").value && selectMatchClient($("matchClient").value);
  $("matchGrant").onchange = () => $("matchGrant").value && selectMatchGrant($("matchGrant").value);
  $("exportMatchesBtn").onclick = exportMatchesCsv;
  $("backupBtn").onclick = exportBackup;
  $("backupFile").onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const imported = JSON.parse(reader.result);
        if (Array.isArray(imported)) data.clients = imported.map(normalizeClient);
        else data = {
          schemaVersion: imported.schemaVersion || DATA_SCHEMA_VERSION,
          clients: (imported.clients || []).map(normalizeClient),
          grants: (imported.grants || []).map(normalizeGrant),
          sources: (imported.sources || []).map(normalizeSource),
          matchHistory: (imported.matchHistory || []).map(normalizeMatchHistory).slice(0, 500),
          autoScan: imported.autoScan || { lastRun: "", lastCount: 0, lastError: "" },
          updatedAt: imported.updatedAt || new Date().toISOString()
        };
        selectedClientId = selectedGrantId = selectedSourceId = null;
        saveData();
        setClientForm(null); setGrantForm(null); setSourceForm(null);
        toast("Backup importato");
      } catch {
        toast("File non valido");
      }
    };
    reader.readAsText(file);
  };
}

function init() {
  fillStaticSelect("c_type", LEGAL_TYPES);
  mergeDefaultSources();
  mergeBundledAutoGrants();
  renderGrantTagPickers();
  setClientForm(null);
  setGrantForm(null);
  setSourceForm(null);
  bindEvents();
  renderAll();
  suppressBackendSync = true;
  saveData();
  suppressBackendSync = false;
  hydrateBackendDatabase();
  startAutoRadar();
}

init();
</script>
</body>
</html>
