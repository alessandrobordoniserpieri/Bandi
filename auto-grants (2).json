<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>BANDI-SCANNER</title>
  <style>
    :root {
      --bg: #eef3f8;
      --panel: #ffffff;
      --ink: #111827;
      --muted: #64748b;
      --line: #dbe3ef;
      --dark: #102033;
      --blue: #1d4ed8;
      --teal: #0f766e;
      --violet: #6d28d9;
      --green: #15803d;
      --amber: #b45309;
      --red: #b91c1c;
      --soft-blue: #eff6ff;
      --soft-green: #ecfdf5;
      --soft-amber: #fffbeb;
      --soft-red: #fef2f2;
      --shadow: 0 18px 44px rgba(15, 23, 42, .09);
      --shadow-soft: 0 8px 22px rgba(15, 23, 42, .06);
      --radius: 8px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--ink);
      background:
        linear-gradient(180deg, rgba(15,118,110,.08), transparent 360px),
        radial-gradient(circle at 12% 0%, rgba(29,78,216,.12), transparent 320px),
        var(--bg);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    button, input, textarea, select { font: inherit; }
    button { cursor: pointer; }
    .app { min-height: 100vh; display: grid; grid-template-rows: auto 1fr; }

    header {
      background:
        linear-gradient(135deg, #102033 0%, #12394b 52%, #0f766e 100%);
      color: white;
      border-bottom: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 20px 60px rgba(15,23,42,.22);
    }

    .topbar {
      max-width: 1440px;
      margin: 0 auto;
      padding: 20px 24px 16px;
      display: grid;
      gap: 16px;
    }

    .brandrow {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 18px;
    }

    h1 { font-size: 34px; line-height: 1.05; margin: 0; letter-spacing: 0; }
    .subtitle { color: #cbd5e1; margin: 8px 0 0; max-width: 780px; }
    .brandmark { display: flex; gap: 13px; align-items: center; }
    .logo {
      width: 48px;
      height: 48px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.18);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.06);
      font-weight: 950;
      color: #d1fae5;
    }
    .kpis { display: grid; grid-template-columns: repeat(4, minmax(120px, 1fr)); gap: 10px; }
    .kpi {
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: var(--radius);
      padding: 12px;
      min-height: 76px;
    }
    .kpi span { display: block; color: #cbd5e1; font-size: 12px; font-weight: 700; text-transform: uppercase; }
    .kpi strong { display: block; font-size: 28px; margin-top: 5px; }

    .tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      border-top: 1px solid rgba(255,255,255,.12);
      padding-top: 14px;
    }
    .tab {
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.07);
      color: white;
      border-radius: var(--radius);
      min-height: 40px;
      padding: 0 13px;
      font-weight: 800;
    }
    .tab.active { background: white; color: #0f172a; }

    main { max-width: 1440px; width: 100%; margin: 0 auto; padding: 22px 24px 40px; }
    .view { display: none; }
    .view.active { display: block; }
    .grid { display: grid; grid-template-columns: 390px 1fr; gap: 18px; align-items: start; }
    .three { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
    .two { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .panel:hover { box-shadow: var(--shadow-soft); }
    .pad { padding: 18px; }
    .panel h2, .panel h3 { margin: 0 0 8px; }
    .hint { color: var(--muted); font-size: 14px; margin: 0 0 14px; line-height: 1.45; }
    .section { border-top: 1px solid var(--line); margin-top: 18px; padding-top: 18px; }
    .section-title { margin: 0 0 12px; font-size: 16px; font-weight: 900; }

    .toolbar { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin: 12px 0; }
    .btn {
      border: 0;
      background: linear-gradient(135deg, var(--dark), #1f3b57);
      color: white;
      border-radius: var(--radius);
      min-height: 42px;
      padding: 0 14px;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn.secondary { background: #e2e8f0; color: #0f172a; }
    .btn.good { background: var(--green); }
    .btn.warn { background: var(--amber); }
    .btn.bad { background: var(--red); }
    .btn.ghost { background: transparent; color: #0f172a; border: 1px solid var(--line); }
    .btn:disabled { opacity: .48; cursor: not-allowed; }

    label.label { display: block; font-size: 12px; color: #334155; font-weight: 900; margin: 0 0 6px; text-transform: uppercase; }
    input, select, textarea {
      width: 100%;
      border: 1px solid var(--line);
      background: #ffffff;
      color: var(--ink);
      border-radius: var(--radius);
      padding: 11px 12px;
      outline: none;
      min-height: 42px;
    }
    textarea { resize: vertical; min-height: 92px; line-height: 1.35; }
    input:focus, select:focus, textarea:focus { border-color: #93c5fd; box-shadow: 0 0 0 4px #dbeafe; }
    .uploadbox {
      border: 1px dashed #9fb4cc;
      background: linear-gradient(180deg, #f8fbff, #eef7f6);
      border-radius: var(--radius);
      padding: 16px;
    }
    .doc-list { display: grid; gap: 8px; margin-top: 10px; }
    .doc-item {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 10px 12px;
      background: #fff;
      display: grid;
      gap: 4px;
    }
    .doc-item strong { overflow-wrap: anywhere; }
    .insight {
      border-left: 4px solid var(--teal);
      background: #f0fdfa;
      border-radius: var(--radius);
      padding: 12px;
      color: #134e4a;
    }
    .fieldgrid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .full { grid-column: 1 / -1; }
    .mini { min-height: 36px; padding: 8px 10px; }

    .list { display: flex; flex-direction: column; gap: 8px; max-height: 720px; overflow: auto; padding-right: 4px; }
    .grant-section { display: grid; gap: 8px; margin-top: 14px; }
    .grant-section h3 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin: 0;
      font-size: 13px;
      text-transform: uppercase;
      color: #334155;
      letter-spacing: 0;
    }
    .grant-section .list { max-height: 420px; }
    .count-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 30px;
      height: 26px;
      padding: 0 8px;
      border-radius: 999px;
      background: #e2e8f0;
      color: #0f172a;
      font-weight: 900;
      font-size: 12px;
    }
    .item {
      text-align: left;
      border: 1px solid var(--line);
      background: white;
      border-radius: var(--radius);
      padding: 12px;
      width: 100%;
    }
    .item.closed { background: #f8fafc; border-color: #e2e8f0; }
    .item.active { border-color: #0f172a; background: #0f172a; color: white; }
    .item small { color: var(--muted); display: block; margin-top: 3px; line-height: 1.35; }
    .item.active small { color: #cbd5e1; }

    .chips { display: flex; flex-wrap: wrap; gap: 7px; }
    .chip, .tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #f8fafc;
      color: #475569;
      min-height: 30px;
      padding: 6px 10px;
      font-size: 12px;
      font-weight: 800;
    }
    .tag.active { background: #0f172a; color: white; border-color: #0f172a; }
    .item.active .chip { background: rgba(255,255,255,.14); color: white; border-color: rgba(255,255,255,.18); }

    .scorebar { height: 10px; background: #e2e8f0; border-radius: 999px; overflow: hidden; }
    .scorebar span { display: block; height: 100%; background: var(--blue); width: 0%; }
    .score-lg { font-size: 42px; font-weight: 950; line-height: 1; }
    .match-row {
      display: grid;
      grid-template-columns: 92px 1fr auto;
      gap: 14px;
      align-items: center;
      border: 1px solid var(--line);
      background: white;
      border-radius: var(--radius);
      padding: 14px;
      margin-bottom: 10px;
    }
    .score-card {
      border-radius: var(--radius);
      padding: 12px;
      text-align: center;
      border: 1px solid var(--line);
      background: var(--soft-blue);
      color: #1e3a8a;
    }
    .score-card.good { background: var(--soft-green); color: #14532d; }
    .score-card.warn { background: var(--soft-amber); color: #78350f; }
    .score-card.bad { background: var(--soft-red); color: #7f1d1d; }
    .reason { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }
    .reason span { border-radius: 999px; background: #f1f5f9; padding: 5px 8px; color: #475569; font-size: 12px; font-weight: 700; }
    .reason .minus { background: #fef2f2; color: #991b1b; }
    .reason .plus { background: #ecfdf5; color: #166534; }
    .mini-match {
      border: 1px solid var(--line);
      background: #fff;
      border-radius: var(--radius);
      padding: 12px;
      text-align: left;
      width: 100%;
      display: grid;
      gap: 8px;
    }
    .mini-match:hover { border-color: #93c5fd; box-shadow: var(--shadow-soft); }
    .match-detail-hero { display: grid; grid-template-columns: 110px 1fr; gap: 14px; align-items: start; }
    .summary-callout {
      border-left: 4px solid var(--blue);
      background: #eff6ff;
      border-radius: var(--radius);
      padding: 12px;
      color: #1e3a8a;
      line-height: 1.45;
    }
    .task-list { display: grid; gap: 8px; }
    .task {
      border: 1px solid var(--line);
      background: #fff;
      border-radius: var(--radius);
      padding: 10px 12px;
    }
    .selector-list { display: grid; gap: 8px; margin-top: 10px; max-height: 320px; overflow: auto; padding-right: 4px; }
    .selector-card {
      text-align: left;
      border: 1px solid var(--line);
      background: #fff;
      border-radius: var(--radius);
      padding: 10px 12px;
      width: 100%;
      display: grid;
      gap: 5px;
    }
    .selector-card:hover { border-color: #93c5fd; box-shadow: var(--shadow-soft); }
    .selector-card.active { background: #0f172a; border-color: #0f172a; color: #fff; }
    .selector-card.active .muted, .selector-card.active .hint { color: #cbd5e1; }
    .inline-score { display: inline-flex; width: fit-content; border-radius: 999px; padding: 4px 8px; background: #eff6ff; color: #1e3a8a; font-size: 12px; font-weight: 900; }
    .deadline-badge {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 5px 9px;
      font-size: 12px;
      font-weight: 900;
      border: 1px solid transparent;
      margin-top: 8px;
    }
    .deadline-open { background: var(--soft-green); color: #166534; border-color: #bbf7d0; }
    .deadline-soon { background: var(--soft-amber); color: #92400e; border-color: #fde68a; }
    .deadline-closed { background: var(--soft-red); color: #991b1b; border-color: #fecaca; }
    .deadline-neutral { background: #f1f5f9; color: #475569; border-color: #e2e8f0; }
    .comparison-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin-top: 10px; }
    .metric-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 10px; }
    .quality-pill {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border-radius: 999px;
      padding: 5px 9px;
      font-size: 12px;
      font-weight: 900;
      background: #eef2ff;
      color: #3730a3;
      border: 1px solid #c7d2fe;
      margin-top: 8px;
    }
    .quality-pill.low { background: var(--soft-red); color: #991b1b; border-color: #fecaca; }
    .quality-pill.mid { background: var(--soft-amber); color: #92400e; border-color: #fde68a; }
    .quality-pill.high { background: var(--soft-green); color: #166534; border-color: #bbf7d0; }
    .breakdown { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; margin-top: 12px; }
    .breakdown-item {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #f8fafc;
      padding: 9px;
      display: grid;
      gap: 6px;
    }
    .breakdown-head { display: flex; justify-content: space-between; gap: 8px; font-size: 12px; font-weight: 900; color: #334155; }
    .mini-bar { height: 7px; background: #e2e8f0; border-radius: 999px; overflow: hidden; }
    .mini-bar span { display: block; height: 100%; background: var(--blue); width: 0%; }
    .advice-list { display: grid; gap: 6px; margin-top: 10px; color: #475569; font-size: 13px; }
    .advice-list span { border-radius: var(--radius); background: #f1f5f9; padding: 7px 9px; }
    .advice-list .plus { background: #ecfdf5; color: #166534; }
    .advice-list .minus { background: #fef2f2; color: #991b1b; }

    .empty {
      border: 1px dashed #cbd5e1;
      color: var(--muted);
      background: #f8fafc;
      border-radius: var(--radius);
      text-align: center;
      padding: 34px 18px;
    }
    .profilebox { display: grid; grid-template-columns: 1fr 220px; gap: 12px; }
    .fact {
      border: 1px solid var(--line);
      background: #f8fafc;
      border-radius: var(--radius);
      padding: 12px;
      min-height: 76px;
    }
    .fact strong { display: block; margin-bottom: 5px; }
    .timeline { display: grid; gap: 10px; }
    .source-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
    .source-card { border: 1px solid var(--line); border-radius: var(--radius); padding: 12px; background: #fff; }
    button.source-card { text-align: left; cursor: pointer; font: inherit; display: grid; gap: 8px; }
    button.source-card:hover { border-color: #93c5fd; box-shadow: var(--shadow-soft); }
    .source-card a { color: #1d4ed8; overflow-wrap: anywhere; font-weight: 800; }
    .auto-status {
      border: 1px solid #bfdbfe;
      background: #eff6ff;
      color: #1e3a8a;
      border-radius: var(--radius);
      padding: 12px;
      margin: 12px 0;
      font-size: 13px;
      line-height: 1.45;
    }
    .auto-status strong { display: block; color: #1e3a8a; margin-bottom: 4px; }
    .toast {
      position: fixed;
      right: 20px;
      bottom: 20px;
      background: #0f172a;
      color: white;
      border-radius: var(--radius);
      padding: 13px 16px;
      box-shadow: 0 16px 42px rgba(0,0,0,.25);
      display: none;
      z-index: 10;
    }
    .toast.show { display: block; }
    .muted { color: var(--muted); }
    .right { margin-left: auto; }
    .hidden { display: none !important; }

    @media (max-width: 1100px) {
      .grid, .three, .source-grid, .comparison-grid, .metric-grid, .breakdown { grid-template-columns: 1fr; }
      .kpis { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .profilebox, .match-row, .match-detail-hero { grid-template-columns: 1fr; }
      .brandrow { display: grid; }
    }
    @media (max-width: 720px) {
      main, .topbar { padding-left: 14px; padding-right: 14px; }
      h1 { font-size: 28px; }
      .fieldgrid, .two { grid-template-columns: 1fr; }
      .kpis { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="app">
  <header>
    <div class="topbar">
      <div class="brandrow">
        <div class="brandmark">
          <div class="logo">BS</div>
          <div>
            <h1>BANDI-SCANNER</h1>
            <p class="subtitle">Piattaforma beta per leggere bandi, costruire profili cliente evoluti e stimare la compatibilità progettuale con punteggi spiegabili.</p>
          </div>
        </div>
        <div class="toolbar">
          <button class="btn secondary" id="backupBtn">Esporta backup</button>
          <label class="btn secondary" for="backupFile">Importa backup</label>
          <input class="hidden" id="backupFile" type="file" accept="application/json" />
        </div>
      </div>
      <div class="kpis">
        <div class="kpi"><span>Clienti</span><strong id="kpiClients">0</strong></div>
        <div class="kpi"><span>Bandi aperti</span><strong id="kpiOpenGrants">0</strong></div>
        <div class="kpi"><span>Match forti</span><strong id="kpiStrongMatches">0</strong></div>
        <div class="kpi"><span>Fonti monitorate</span><strong id="kpiSources">0</strong></div>
      </div>
      <nav class="tabs" aria-label="Sezioni">
        <button class="tab active" data-view="dashboard">Dashboard</button>
        <button class="tab" data-view="clients">Clienti</button>
        <button class="tab" data-view="grants">Bandi</button>
        <button class="tab" data-view="matching">Matching</button>
        <button class="tab" data-view="sources">Fonti</button>
      </nav>
    </div>
  </header>

  <main>
    <section id="view-dashboard" class="view active">
      <div class="three">
        <div class="panel pad">
          <h2>Prossime scadenze</h2>
          <p class="hint">Bandi aperti ordinati per urgenza.</p>
          <div id="deadlineList" class="timeline"></div>
        </div>
        <div class="panel pad">
          <h2>Migliori occasioni</h2>
          <p class="hint">I match più alti tra tutti i clienti e tutti i bandi aperti.</p>
          <div id="topMatches"></div>
        </div>
        <div class="panel pad">
          <h2>Copertura dati</h2>
          <p class="hint">Clienti con profili più ricchi producono valutazioni più affidabili.</p>
          <div id="archiveHealth" class="metric-grid"></div>
          <div id="coverageList"></div>
        </div>
      </div>
    </section>

    <section id="view-clients" class="view">
      <div class="grid">
        <aside class="panel pad">
          <h2>Archivio clienti</h2>
          <p class="hint">Cerca un ente o crea un nuovo profilo.</p>
          <input id="clientSearch" placeholder="Cerca nome, territorio, tag, obiettivi..." />
          <div class="toolbar">
            <button class="btn" id="newClientBtn">Nuovo cliente</button>
            <button class="btn secondary" id="seedClientBtn">Esempio</button>
          </div>
          <div id="clientList" class="list"></div>
        </aside>

        <div>
          <div class="panel pad">
            <h2 id="clientFormTitle">Nuovo profilo cliente</h2>
            <p class="hint">Più campi compili, più il punteggio dei bandi diventa utile e difendibile.</p>
            <div class="section-title">Identità</div>
            <div class="fieldgrid">
              <div><label class="label">Nome ente *</label><input id="c_name" /></div>
              <div><label class="label">Forma giuridica / ruolo</label><select id="c_type"></select></div>
              <div><label class="label">Sede legale</label><input id="c_legalAddress" placeholder="Via, numero civico, CAP" /></div>
              <div><label class="label">Comune</label><input id="c_city" placeholder="Es. Rimini" /></div>
              <div><label class="label">Provincia</label><input id="c_province" placeholder="Es. RN" /></div>
              <div><label class="label">Regione</label><input id="c_region" placeholder="Es. Emilia-Romagna" /></div>
              <div><label class="label">Sede operativa / impianti</label><input id="c_operationalSite" placeholder="Sede, campo, palestra, centro..." /></div>
              <div><label class="label">Area operativa</label><input id="c_area" placeholder="Quartieri, comuni, province o regioni servite" /></div>
              <div><label class="label">Ambito geografico</label><select id="c_geoScope"><option>Comunale</option><option>Provinciale</option><option>Regionale</option><option>Nazionale</option><option>Europeo</option></select></div>
              <div><label class="label">Stato rapporto</label><select id="c_status"><option>Cliente potenziale</option><option>Cliente attivo</option><option>Ente proprio</option><option>Partner</option><option>Da ricontattare</option></select></div>
              <div><label class="label">Referente</label><input id="c_contact" /></div>
              <div><label class="label">Email / telefono</label><input id="c_contactInfo" /></div>
              <div><label class="label">Sito / social</label><input id="c_website" /></div>
              <div><label class="label">CF / P.IVA</label><input id="c_vat" /></div>
              <div><label class="label">Anno costituzione</label><input id="c_founded" type="number" min="1800" max="2100" /></div>
            </div>

            <div class="section">
              <div class="section-title">Compatibilità amministrativa</div>
              <div class="fieldgrid">
                <div><label class="label">Capacità gestionale</label><select id="c_capacity"><option>Bassa</option><option>Media</option><option>Alta</option></select></div>
                <div><label class="label">Priorità commerciale: <span id="priorityOut">7</span>/10</label><input id="c_priority" type="range" min="1" max="10" value="7" /></div>
                <div><label class="label">Budget annuo indicativo</label><input id="c_budget" placeholder="Es. 80.000" /></div>
                <div><label class="label">Cofinanziamento sostenibile</label><input id="c_cofunding" placeholder="Es. 20%" /></div>
                <div><label class="label">Staff / collaboratori</label><input id="c_staff" /></div>
                <div><label class="label">Volontari / rete</label><input id="c_volunteers" /></div>
                <div><label class="label">Spazi / impianti</label><input id="c_spaces" /></div>
