const $ = id => document.getElementById(id);
const esc = value => String(value ?? "").replace(/[&<>'"]/g, m => ({ "&":"&amp;", "<":"&lt;", ">":"&gt;", "'":"&#39;", '"':"&quot;" }[m]));
const uid = prefix => `${prefix}_${Date.now()}_${Math.random().toString(16).slice(2)}`;

let data = loadData();
let selectedClientId = null;
let selectedGrantId = null;
let selectedSourceId = null;
let clientTags = [];
let clientDocs = [];
let grantTags = [];
let grantTypes = [];
let lastMatchRows = [];
let selectedMatch = null;
let syncTimer = null;
let suppressBackendSync = false;

function nextDate(days) {
  const d = new Date();
  d.setDate(d.getDate() + days);
  return d.toISOString().slice(0, 10);
}

function loadData() {
  const saved = JSON.parse(localStorage.getItem(STORE) || "null");
  if (saved && saved.clients && saved.grants && saved.sources) {
    return {
      schemaVersion: saved.schemaVersion || DATA_SCHEMA_VERSION,
      clients: saved.clients.map(normalizeClient),
      grants: saved.grants.map(normalizeGrant),
      sources: saved.sources.map(normalizeSource),
      matchHistory: (saved.matchHistory || []).map(normalizeMatchHistory).slice(0, 500),
      autoScan: saved.autoScan || { lastRun: "", lastCount: 0, lastError: "" },
      updatedAt: saved.updatedAt || new Date().toISOString()
    };
  }

  const legacy = JSON.parse(localStorage.getItem(LEGACY_CLIENTS) || "[]");
  const clients = Array.isArray(legacy) && legacy.length
    ? legacy.map(c => normalizeClient(c))
    : [];
  return { schemaVersion: DATA_SCHEMA_VERSION, clients, grants: [], sources: DEFAULT_SOURCES.map(normalizeSource), matchHistory: [], autoScan: { lastRun: "", lastCount: 0, lastError: "" }, updatedAt: new Date().toISOString() };
}

function persistData() {
  data.schemaVersion = DATA_SCHEMA_VERSION;
  data.updatedAt = new Date().toISOString();
  localStorage.setItem(STORE, JSON.stringify(data));
  if (!suppressBackendSync) scheduleBackendSync();
}

function saveData() {
  persistData();
  renderAll();
}

function normalizeClient(c) {
  const city = c.city || "";
  const province = c.province || "";
  const region = c.region || "";
  const area = c.area || [city, province, region].filter(Boolean).join(" / ");
  const docs = (c.documentFiles || []).map(normalizeClientDocument);
  return {
    id: c.id || uid("c"), name: c.name || "", type: legalTypeDisplay(c.type || "ASD"),
    legalAddress: c.legalAddress || "", city, province, region, operationalSite: c.operationalSite || "", area, geoScope: c.geoScope || "Provinciale",
    status: c.status || "Cliente potenziale", contact: c.contact || "", contactInfo: c.contactInfo || "", website: c.website || "",
    vat: c.vat || "", founded: c.founded || "", capacity: c.capacity || "Media", priority: Number(c.priority || 7),
    budget: c.budget || "", cofunding: c.cofunding || "", staff: c.staff || "", volunteers: c.volunteers || "",
    statuteStatus: c.statuteStatus || "Non verificato", financialReports: c.financialReports || "Non verificato",
    registryRunts: c.registryRunts || "Non applicabile", registryRasd: c.registryRasd || "Non applicabile", registryOther: c.registryOther || "",
    rasdName: c.rasdName || "", rasdNumber: c.rasdNumber || "", sportBody: c.sportBody || "", sportActivities: c.sportActivities || "",
    rasdCheckStatus: c.rasdCheckStatus || "Non avviato", rasdLastCheck: c.rasdLastCheck || "",
    spaces: c.spaces || "", documents: c.documents || "", documentFiles: docs, documentInsights: c.documentInsights || buildDocumentInsights(docs), documentTags: (c.documentTags || []).length ? c.documentTags : extractDocumentTags(docs),
    fundingInsights: c.fundingInsights || buildFundingInsights(docs), fundingTypes: (c.fundingTypes || []).length ? c.fundingTypes : extractFundingTypes(docs), winningCriteria: (c.winningCriteria || []).length ? c.winningCriteria : extractWinningCriteria(docs),
    tags: c.tags || [], activities: c.activities || c.strengths || "",
    strengths: c.strengths || "", weaknesses: c.weaknesses || "", publicPartners: c.publicPartners || "",
    privatePartners: c.privatePartners || "", projectHistory: c.projectHistory || "", fundedProjects: c.fundedProjects || "", reportingHistory: c.reportingHistory || "",
    goals: c.goals || "", notes: c.notes || "",
    createdAt: c.createdAt || new Date().toISOString(), updatedAt: new Date().toISOString()
  };
}

function normalizeClientDocument(doc) {
  const text = doc.text || doc.name || "";
  const funding = doc.fundingType ? {
    fundingType: doc.fundingType,
    fundingEvidence: doc.fundingEvidence || [],
    winningCriteria: doc.winningCriteria || []
  } : inferFundingSignals(text);
  return {
    id: doc.id || uid("doc"),
    name: doc.name || "Documento",
    type: doc.type || "documento",
    size: doc.size || 0,
    uploadedAt: doc.uploadedAt || new Date().toISOString(),
    text,
    preview: doc.preview || cleanText(text).slice(0, 260),
    extractionMethod: doc.extractionMethod || "lettura precedente",
    extractionQuality: Number(doc.extractionQuality || documentExtractionQuality(text)),
    tags: doc.tags || inferTagsFromText(text),
    projectSignals: doc.projectSignals || inferProjectSignals(text),
    ...funding
  };
}

function normalizeGrant(g) {
  return {
    id: g.id || uid("g"), title: g.title || "", provider: g.provider || "", sourceId: g.sourceId || "", url: g.url || "",
    status: g.status || "Aperto", deadline: g.deadline || "", area: g.area || "", geoScope: g.geoScope || "Nazionale",
    amount: g.amount || "", cofunding: g.cofunding || "", eligibleTypes: g.eligibleTypes || [],
    tags: g.tags || [], minCapacity: g.minCapacity || "Media", complexity: g.complexity || "Media",
    requirements: g.requirements || "", expenses: g.expenses || "", summary: g.summary || "", notes: g.notes || "",
    beneficiaries: g.beneficiaries || "", detail: g.detail || "", importMode: g.importMode || "", discoveredAt: g.discoveredAt || "",
    createdAt: g.createdAt || new Date().toISOString(), updatedAt: new Date().toISOString()
  };
}

function normalizeSource(s) {
  return {
    id: s.id || uid("s"), name: s.name || "", type: s.type || "Altro", url: s.url || "", frequency: s.frequency || "Settimanale",
    lastCheck: s.lastCheck || "", notes: s.notes || "", createdAt: s.createdAt || new Date().toISOString(), updatedAt: new Date().toISOString()
  };
}

function normalizeMatchHistory(m) {
  return {
    id: m.id || uid("mh"),
    clientId: m.clientId || "",
    clientName: m.clientName || "",
    grantId: m.grantId || "",
    grantTitle: m.grantTitle || "",
    grantStatus: m.grantStatus || "",
    deadline: m.deadline || "",
    score: Number(m.score || 0),
    decision: m.decision || "",
    documentScore: Number(m.documentScore || 0),
    reasons: m.reasons || [],
    risks: m.risks || [],
    actions: m.actions || [],
    origin: m.origin || "matching",
    createdAt: m.createdAt || new Date().toISOString()
  };
}

function toast(msg) {
  const t = $("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(() => t.classList.remove("show"), 2300);
}

function switchView(view) {
  document.querySelectorAll(".tab").forEach(b => b.classList.toggle("active", b.dataset.view === view));
  document.querySelectorAll(".view").forEach(v => v.classList.toggle("active", v.id === `view-${view}`));
}

function renderTagPicker(rootId, options, selected, onChange) {
  const root = $(rootId);
  root.innerHTML = "";
  options.forEach(tag => {
    const b = document.createElement("button");
    b.type = "button";
    b.className = "tag" + (selected.includes(tag) ? " active" : "");
    b.textContent = tag;
    b.onclick = () => onChange(selected.includes(tag) ? selected.filter(t => t !== tag) : [...selected, tag]);
    root.appendChild(b);
  });
}

function fillSelect(id, items, placeholder, selected = "") {
  const el = $(id);
  el.innerHTML = `<option value="">${esc(placeholder)}</option>` + items.map(x => `<option value="${esc(x.id)}">${esc(x.name || x.title)}</option>`).join("");
  el.value = selected || "";
}

function fillStaticSelect(id, values) {
  const el = $(id);
  el.innerHTML = values.map(v => `<option>${esc(v)}</option>`).join("");
}

function renderAll() {
  renderKpis();
  renderClients();
  renderGrants();
  renderSources();
  renderMatchSelectors();
  renderDashboard();
  renderMatchDetail(selectedMatch);
  renderAutoStatus();
}

function renderKpis() {
  $("kpiClients").textContent = data.clients.length;
  $("kpiOpenGrants").textContent = data.grants.filter(g => isOpenGrant(g)).length;
  $("kpiSources").textContent = data.sources.length;
  $("kpiStrongMatches").textContent = allMatches().filter(m => m.score >= 75).length;
}

function renderAutoStatus(message = "") {
  const el = $("autoStatus");
  if (!el) return;
  const last = data.autoScan?.lastRun ? new Date(data.autoScan.lastRun).toLocaleString("it-IT") : "mai";
  const count = data.autoScan?.lastCount || 0;
  const error = data.autoScan?.lastError ? `<br><span>Ultimo errore: ${esc(data.autoScan.lastError)}</span>` : "";
  el.innerHTML = `<strong>Radar automatico attivo</strong>${message || `Controllo fonti ogni ${SOURCE_REFRESH_HOURS} ore mentre l'app è aperta. Ultimo controllo: ${esc(last)}. Nuovi bandi trovati: ${count}.`}${error}`;
}

function renderClients() {
  const q = $("clientSearch").value.toLowerCase();
  const list = $("clientList");
  const items = data.clients.filter(c => clientText(c).toLowerCase().includes(q));
  list.innerHTML = items.length ? "" : `<div class="empty">Nessun cliente trovato.</div>`;
  items.forEach(c => {
    const btn = document.createElement("button");
    btn.className = "item" + (c.id === selectedClientId ? " active" : "");
    btn.innerHTML = `<strong>${esc(c.name || "Senza nome")}</strong><small>${esc(c.type)} · ${esc(c.area || "-")} · priorità ${esc(c.priority)}/10</small><div class="chips">${(c.tags || []).slice(0,5).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div>`;
    btn.onclick = () => setClientForm(c);
    list.appendChild(btn);
  });
}

function renderGrants() {
  const q = $("grantSearch").value.toLowerCase();
  const items = data.grants.filter(g => grantText(g).toLowerCase().includes(q));
  const open = items.filter(isOpenGrant).sort((a,b) => deadlineDays(a.deadline) - deadlineDays(b.deadline));
  const closed = items.filter(isClosedGrant).sort((a,b) => closeSortDate(b) - closeSortDate(a));
  $("openGrantCount").textContent = open.length;
  $("closedGrantCount").textContent = closed.length;
  renderGrantList("grantListOpen", open, `<div class="empty">Nessun bando aperto trovato.</div>`);
  renderGrantList("grantListClosed", closed, `<div class="empty">Lo storico dei bandi chiusi si popolerà automaticamente quando le scadenze saranno superate.</div>`);
}

function renderGrantList(rootId, items, emptyHtml) {
  const list = $(rootId);
  list.innerHTML = items.length ? "" : emptyHtml;
  items.forEach(g => list.appendChild(grantListItem(g)));
}

function grantListItem(g) {
  const quality = grantDataQuality(g);
  const btn = document.createElement("button");
  btn.className = "item" + (isClosedGrant(g) ? " closed" : "") + (g.id === selectedGrantId ? " active" : "");
  btn.innerHTML = `<strong>${esc(g.title || "Senza titolo")}</strong><small>${esc(g.provider || "-")} · ${esc(normalizedGrantStatus(g))}</small>${deadlineBadge(g)}${qualityBadge(quality)}<p class="hint">${esc(g.summary || "Scheda in aggiornamento automatico.").slice(0, 180)}</p><div class="chips">${(g.tags || []).slice(0,5).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div>`;
  btn.onclick = () => setGrantForm(g);
  return btn;
}

function renderSources() {
  fillSelect("g_source", data.sources, "Nessuna fonte", $("g_source").value);
  const q = $("sourceSearch").value.toLowerCase();
  const list = $("sourceList");
  const items = data.sources.filter(s => `${s.name} ${s.type} ${s.url} ${s.notes}`.toLowerCase().includes(q));
  list.innerHTML = items.length ? "" : `<div class="empty">Nessuna fonte trovata.</div>`;
  items.forEach(s => {
    const btn = document.createElement("button");
    btn.className = "item" + (s.id === selectedSourceId ? " active" : "");
    btn.innerHTML = `<strong>${esc(s.name || "Senza nome")}</strong><small>${esc(s.type)} · ${esc(s.frequency)}</small>`;
    btn.onclick = () => setSourceForm(s);
    list.appendChild(btn);
  });
  $("sourceCards").innerHTML = data.sources.map(s => `<div class="source-card"><strong>${esc(s.name)}</strong><p class="hint">${esc(s.type)} · ${esc(s.frequency)}</p>${s.url ? `<a href="${esc(s.url)}" target="_blank" rel="noreferrer">Apri fonte</a>` : ""}<p class="hint">${esc(s.notes || "")}</p></div>`).join("");
}

function renderMatchSelectors() {
  fillSelect("matchClient", data.clients, "Seleziona cliente", $("matchClient").value);
  fillSelect("matchGrant", data.grants, "Seleziona bando", $("matchGrant").value);
  renderMatchPickers();
}

function renderMatchPickers() {
  const clientRoot = $("matchClientPicker");
  const grantRoot = $("matchGrantPicker");
  if (!clientRoot || !grantRoot) return;
  const clientQuery = ($("matchClientSearch")?.value || "").toLowerCase();
  const grantQuery = ($("matchGrantSearch")?.value || "").toLowerCase();
  const selectedClient = $("matchClient").value;
  const selectedGrant = $("matchGrant").value;
  const clients = data.clients
    .filter(c => clientText(c).toLowerCase().includes(clientQuery))
    .sort((a,b) => bestClientScore(b) - bestClientScore(a))
    .slice(0, 8);
  const grants = data.grants
    .filter(g => grantText(g).toLowerCase().includes(grantQuery))
    .sort((a,b) => Number(isClosedGrant(a)) - Number(isClosedGrant(b)) || bestGrantScore(b) - bestGrantScore(a))
    .slice(0, 8);
  const clientHint = clientQuery ? `Risultati cliente per "${clientQuery}"` : "Clienti ordinati per miglior opportunità";
  const grantHint = grantQuery ? `Risultati bando per "${grantQuery}"` : "Bandi ordinati per miglior cliente";
  clientRoot.innerHTML = clients.length ? clients.map(c => selectorCard({
    id: c.id,
    active: c.id === selectedClient,
    title: c.name || "Senza nome",
    meta: `${c.type} · ${c.area || "-"}`,
    score: data.grants.length ? `miglior match ${bestClientScore(c)}/100` : "nessun bando",
    onclick: `selectMatchClient('${c.id}')`
  })).join("") : `<div class="empty">Nessun cliente trovato.</div>`;
  if (clients.length) clientRoot.insertAdjacentHTML("afterbegin", `<span class="muted">${esc(clientHint)}</span>`);
  grantRoot.innerHTML = grants.length ? grants.map(g => selectorCard({
    id: g.id,
    active: g.id === selectedGrant,
    title: g.title || "Senza titolo",
    meta: `${g.provider || "-"} · ${normalizedGrantStatus(g)} · ${deadlineLabel(g.deadline)}`,
    score: data.clients.length ? `miglior cliente ${bestGrantScore(g)}/100` : "nessun cliente",
    onclick: `selectMatchGrant('${g.id}')`
  })).join("") : `<div class="empty">Nessun bando trovato.</div>`;
  if (grants.length) grantRoot.insertAdjacentHTML("afterbegin", `<span class="muted">${esc(grantHint)}</span>`);
}

function selectorCard({ active, title, meta, score, onclick }) {
  return `<button class="selector-card${active ? " active" : ""}" type="button" onclick="${onclick}"><strong>${esc(title)}</strong><span class="muted">${esc(meta)}</span><span class="inline-score">${esc(score)}</span></button>`;
}

function bestClientScore(client) {
  if (!data.grants.length) return 0;
  return Math.max(...data.grants.map(grant => calculateMatch(client, grant).score));
}

function bestGrantScore(grant) {
  if (!data.clients.length) return 0;
  return Math.max(...data.clients.map(client => calculateMatch(client, grant).score));
}

function renderDashboard() {
  const open = data.grants.filter(isOpenGrant).sort((a,b) => deadlineDays(a.deadline) - deadlineDays(b.deadline));
  $("deadlineList").innerHTML = open.length ? open.slice(0,6).map(g => `<div class="fact"><strong>${esc(g.title)}</strong>${deadlineBadge(g)}<p class="hint">${esc(g.provider || "-")}</p></div>`).join("") : `<div class="empty">Nessun bando aperto.</div>`;
  const top = allMatches().slice(0,5);
  $("topMatches").innerHTML = top.length ? top.map(m => miniMatch(m)).join("") : `<div class="empty">Servono almeno un cliente e un bando.</div>`;
  renderArchiveHealth();
  $("coverageList").innerHTML = data.clients.length ? data.clients.map(c => {
    const score = profileCompleteness(c);
    return `<div class="fact"><strong>${esc(c.name || "Senza nome")}</strong><div class="scorebar"><span style="width:${score}%"></span></div><p class="hint">${score}% scheda compilata</p></div>`;
  }).join("") : `<div class="empty">Nessun cliente ancora caricato.</div>`;
}

function renderArchiveHealth() {
  const el = $("archiveHealth");
  if (!el) return;
  const closed = data.grants.filter(isClosedGrant).length;
  const history = (data.matchHistory || []).length;
  const docReady = data.clients.filter(c => clientDocumentProfile(c).score >= 65).length;
  el.innerHTML = `<div class="fact"><strong>Storico bandi</strong><p>${closed} schede chiuse</p></div><div class="fact"><strong>Analisi match</strong><p>${history} salvate</p></div><div class="fact"><strong>Fascicoli pronti</strong><p>${docReady}/${data.clients.length || 0} clienti</p></div>`;
}

function miniMatch(m) {
  return `<button class="mini-match" type="button" onclick="openMatchDetail('${m.client.id}','${m.grant.id}', true)"><strong>${m.score}/100 · ${esc(m.client.name)}</strong><p class="hint">${esc(m.grant.title)}</p><div class="scorebar"><span style="width:${m.score}%"></span></div><span class="muted">Apri analisi del punteggio</span></button>`;
}

function renderClientTagPickers() {
  renderTagPicker("clientTags", TAGS, clientTags, next => {
    clientTags = next;
    renderClientTagPickers();
  });
}

function renderClientDocuments() {
  const list = $("clientDocList");
  const insights = $("clientDocInsights");
  if (!list || !insights) return;
  if (!clientDocs.length) {
    list.innerHTML = "";
    insights.textContent = "Nessun documento caricato.";
    return;
  }
  const tags = extractDocumentTags(clientDocs);
  const suggestions = buildClientSuggestionsFromDocuments(clientDocs);
  insights.innerHTML = `<strong>Analisi documenti:</strong> ${esc(buildDocumentInsights(clientDocs))}${suggestions.summary ? `<p class="hint" style="margin-top:8px">${esc(suggestions.summary)}</p>` : ""}${tags.length ? `<div class="chips" style="margin-top:8px">${tags.map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div>` : ""}`;
  list.innerHTML = clientDocs.map(doc => `<div class="doc-item"><strong>${esc(doc.name)}</strong><small>${esc(formatBytes(doc.size))} · ${esc(doc.type || "documento")} · ${esc(new Date(doc.uploadedAt).toLocaleString("it-IT"))}</small><span class="muted">${esc(doc.preview || "Documento registrato come allegato. Il contenuto completo non viene duplicato nella beta.")}</span><div class="chips"><span class="chip">lettura ${esc(doc.extractionQuality || documentExtractionQuality(doc.text))}%</span><span class="chip">${esc(doc.extractionMethod || "best effort")}</span>${doc.fundingType && doc.fundingType !== "Non rilevato" ? `<span class="chip">${esc(doc.fundingType)}</span>` : ""}${(doc.winningCriteria || []).slice(0,4).map(c => `<span class="chip">${esc(c)}</span>`).join("")}</div></div>`).join("");
}

async function handleClientDocumentUpload(files) {
  const incoming = Array.from(files || []);
  if (!incoming.length) return;
  const docs = await Promise.all(incoming.map(readClientDocument));
  clientDocs = [...clientDocs, ...docs].slice(-12);
  renderClientDocuments();
  const applied = applyDocumentSuggestionsToClientForm({ silent: true, auto: true });
  runRasdComparison({ silent: true });
  toast(applied ? "Documenti analizzati: profilo compilato automaticamente" : "Documenti analizzati e collegati al profilo");
}

function applyDocumentSuggestionsToClientForm(options = {}) {
  if (!clientDocs.length) {
    if (!options.silent) toast("Carica prima almeno un documento");
    return 0;
  }
  const suggestions = buildClientSuggestionsFromDocuments(clientDocs);
  let applied = 0;
  applied += applyFieldSuggestion("c_type", suggestions.type, true);
  applied += applyFieldSuggestion("c_name", suggestions.name);
  applied += applyFieldSuggestion("c_legalAddress", suggestions.legalAddress);
  applied += applyFieldSuggestion("c_city", suggestions.city);
  applied += applyFieldSuggestion("c_province", suggestions.province);
  applied += applyFieldSuggestion("c_region", suggestions.region);
  applied += applyFieldSuggestion("c_area", suggestions.area);
  applied += applyFieldSuggestion("c_vat", suggestions.vat);
  applied += applyFieldSuggestion("c_founded", suggestions.founded);
  applied += applyFieldSuggestion("c_capacity", suggestions.capacity, true);
  applied += applyFieldSuggestion("c_statuteStatus", suggestions.statuteStatus, true);
  applied += applyFieldSuggestion("c_financialReports", suggestions.financialReports, true);
  applied += applyFieldSuggestion("c_registryRunts", suggestions.registryRunts, true);
  applied += applyFieldSuggestion("c_registryRasd", suggestions.registryRasd, true);
  applied += applyFieldSuggestion("c_rasdName", suggestions.rasdName);
  applied += applyFieldSuggestion("c_rasdNumber", suggestions.rasdNumber);
  applied += applyFieldSuggestion("c_sportBody", suggestions.sportBody);
  applied += applyFieldSuggestion("c_sportActivities", suggestions.sportActivities);
  applied += applyFieldSuggestion("c_documents", suggestions.documents);
  applied += appendTextareaSuggestion("c_activities", suggestions.activities);
  applied += appendTextareaSuggestion("c_publicPartners", suggestions.publicPartners);
  applied += appendTextareaSuggestion("c_privatePartners", suggestions.privatePartners);
  applied += appendTextareaSuggestion("c_projectHistory", suggestions.projectHistory);
  applied += appendTextareaSuggestion("c_fundedProjects", suggestions.fundedProjects);
  applied += appendTextareaSuggestion("c_reportingHistory", suggestions.reportingHistory);
  const docTags = extractDocumentTags(clientDocs);
  if (docTags.length) {
    clientTags = [...new Set([...clientTags, ...docTags])].slice(0, 18);
    renderClientTagPickers();
    applied += docTags.length;
  }
  renderClientDocuments();
  renderClientPreview(getClientForm());
  if (!options.silent) toast(applied ? "Profilo aggiornato con i segnali dei documenti" : "Non ho trovato nuovi campi da applicare");
  return applied;
}

function applyFieldSuggestion(id, value, overwriteSelect = false) {
  const el = $(id);
  if (!el || !value) return 0;
  if (el.tagName === "SELECT") {
    if (!overwriteSelect && el.value) return 0;
    const option = [...el.options].find(o => o.value === value || o.textContent === value);
    if (!option) return 0;
    el.value = option.value;
    return 1;
  }
  if (el.value.trim()) return 0;
  el.value = value;
  return 1;
}

function appendTextareaSuggestion(id, value) {
  const el = $(id);
  if (!el || !value) return 0;
  const clean = cleanText(value);
  if (!clean || el.value.toLowerCase().includes(clean.toLowerCase())) return 0;
  el.value = el.value.trim() ? `${el.value.trim()}\n${clean}` : clean;
  return 1;
}

function readClientDocument(file) {
  return new Promise(resolve => {
    const reader = new FileReader();
    const base = {
      id: uid("doc"),
      name: file.name,
      type: file.type || file.name.split(".").pop() || "documento",
      size: file.size,
      uploadedAt: new Date().toISOString()
    };
    reader.onload = async () => {
      const extraction = reader.result instanceof ArrayBuffer
        ? await extractBinaryDocumentText(file, reader.result)
        : { text: String(reader.result || ""), method: "testo diretto" };
      const text = extraction.text.slice(0, 36000);
      const fundingSignals = inferFundingSignals(text);
      resolve({ ...base, text, preview: cleanText(text).slice(0, 260), extractionMethod: extraction.method, extractionQuality: documentExtractionQuality(text), tags: inferTagsFromText(text), projectSignals: inferProjectSignals(text), ...fundingSignals });
    };
    reader.onerror = () => resolve({ ...base, text: "", preview: "File registrato. Testo non leggibile automaticamente in questa beta.", tags: inferTagsFromText(file.name), projectSignals: inferProjectSignals(file.name), ...inferFundingSignals(file.name) });
    if (/text|json|csv|rtf|xml|markdown/i.test(file.type) || /\.(txt|md|csv|json|rtf)$/i.test(file.name)) reader.readAsText(file);
    else if (/pdf|word|officedocument|msword/i.test(file.type) || /\.(pdf|doc|docx|odt)$/i.test(file.name)) reader.readAsArrayBuffer(file);
    else resolve({ ...base, text: file.name, preview: "Documento caricato come allegato. Formato non leggibile automaticamente in questa beta.", tags: inferTagsFromText(file.name), projectSignals: inferProjectSignals(file.name), ...inferFundingSignals(file.name) });
  });
}

async function extractBinaryDocumentText(file, buffer) {
  const lowerName = file.name.toLowerCase();
  if (/\.docx$/.test(lowerName) || /officedocument\.wordprocessingml/i.test(file.type)) {
    const text = await extractDocxText(buffer);
    if (text.length > 80) return { text: `${file.name} ${text}`, method: "DOCX strutturato" };
  }
  if (/\.pdf$/.test(lowerName) || /pdf/i.test(file.type)) {
    const text = await extractPdfText(buffer);
    if (text.length > 80) return { text: `${file.name} ${text}`, method: "PDF testuale avanzato" };
  }
  const bytes = new Uint8Array(buffer);
  const utf8 = new TextDecoder("utf-8", { fatal: false }).decode(bytes);
  let latin = "";
  const step = 8192;
  for (let i = 0; i < bytes.length; i += step) latin += String.fromCharCode(...bytes.slice(i, i + step));
  const pdfStrings = [...latin.matchAll(/\(([^()]{3,})\)/g)].map(m => m[1]).join(" ");
  const xmlText = utf8.replace(/<[^>]+>/g, " ");
  const readable = `${file.name} ${pdfStrings} ${xmlText}`.replace(/[^\x09\x0A\x0D\x20-\x7EÀ-ÿ]+/g, " ");
  return { text: cleanText(readable), method: "lettura binaria best effort" };
}

async function extractDocxText(buffer) {
  const entries = await extractZipEntries(buffer, [/^word\/document\.xml$/, /^word\/header\d*\.xml$/, /^word\/footer\d*\.xml$/]);
  const xml = entries.map(entry => new TextDecoder("utf-8", { fatal: false }).decode(entry.bytes)).join(" ");
  return cleanText(decodeXmlEntities(xml
    .replace(/<w:tab[^>]*\/>/g, " ")
    .replace(/<w:br[^>]*\/>/g, "\n")
    .replace(/<\/w:p>/g, "\n")
    .replace(/<[^>]+>/g, " ")));
}

async function extractZipEntries(buffer, wantedPatterns) {
  const view = new DataView(buffer);
  const bytes = new Uint8Array(buffer);
  const entries = [];
  let offset = 0;
  while (offset + 30 < bytes.length) {
    const signature = view.getUint32(offset, true);
    if (signature !== 0x04034b50) { offset += 1; continue; }
    const method = view.getUint16(offset + 8, true);
    const compressedSize = view.getUint32(offset + 18, true);
    const uncompressedSize = view.getUint32(offset + 22, true);
    const nameLength = view.getUint16(offset + 26, true);
    const extraLength = view.getUint16(offset + 28, true);
    const nameStart = offset + 30;
    const name = new TextDecoder("utf-8", { fatal: false }).decode(bytes.slice(nameStart, nameStart + nameLength));
    const dataStart = nameStart + nameLength + extraLength;
    const dataEnd = dataStart + compressedSize;
    if (dataEnd > bytes.length || compressedSize <= 0) { offset = dataStart + Math.max(0, compressedSize); continue; }
    if (wantedPatterns.some(pattern => pattern.test(name))) {
      const compressed = bytes.slice(dataStart, dataEnd);
      let entryBytes = compressed;
      if (method === 8) entryBytes = await inflateBytes(compressed, "deflate-raw") || await inflateBytes(compressed, "deflate") || new Uint8Array();
      else if (method !== 0) entryBytes = new Uint8Array();
      if (entryBytes.length || uncompressedSize === 0) entries.push({ name, bytes: entryBytes });
    }
    offset = dataEnd;
  }
  return entries;
}

async function inflateBytes(bytes, format) {
  if (typeof DecompressionStream === "undefined") return null;
  try {
    const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream(format));
    return new Uint8Array(await new Response(stream).arrayBuffer());
  } catch {
    return null;
  }
}

async function extractPdfText(buffer) {
  const bytes = new Uint8Array(buffer);
  const latin = bytesToLatin1(bytes);
  const chunks = [latin];
  const streamRegex = /<<[\s\S]{0,800}?\/FlateDecode[\s\S]{0,800}?>>\s*stream\r?\n([\s\S]*?)\r?\nendstream/g;
  for (const match of latin.matchAll(streamRegex)) {
    const streamBytes = latin1ToBytes(match[1]);
    const inflated = await inflateBytes(streamBytes, "deflate") || await inflateBytes(streamBytes, "deflate-raw");
    if (inflated?.length) chunks.push(bytesToLatin1(inflated));
  }
  return cleanText(chunks.map(extractPdfTextFromChunk).join(" "));
}

function extractPdfTextFromChunk(chunk) {
  const literals = [...chunk.matchAll(/\((?:\\.|[^\\()]){2,}\)/g)].map(match => decodePdfLiteral(match[0]));
  const hexes = [...chunk.matchAll(/<([0-9A-Fa-f\s]{6,})>/g)].map(match => decodePdfHex(match[1]));
  return cleanText([...literals, ...hexes].join(" ").replace(/[^\x09\x0A\x0D\x20-\x7EÀ-ÿ]+/g, " "));
}

function decodePdfLiteral(value = "") {
  const body = value.slice(1, -1);
  return body
    .replace(/\\([nrtbf()\\])/g, (_, ch) => ({ n:"\n", r:"\r", t:"\t", b:"", f:"", "(":"(", ")":")", "\\":"\\" }[ch] || ch))
    .replace(/\\([0-7]{1,3})/g, (_, oct) => String.fromCharCode(parseInt(oct, 8)));
}

function decodePdfHex(value = "") {
  const hex = value.replace(/\s+/g, "");
  const bytes = [];
  for (let i = 0; i < hex.length - 1; i += 2) bytes.push(parseInt(hex.slice(i, i + 2), 16));
  if (bytes[0] === 0xfe && bytes[1] === 0xff) {
    let text = "";
    for (let i = 2; i + 1 < bytes.length; i += 2) text += String.fromCharCode((bytes[i] << 8) + bytes[i + 1]);
    return text;
  }
  return String.fromCharCode(...bytes);
}

function bytesToLatin1(bytes) {
  let out = "";
  const step = 8192;
  for (let i = 0; i < bytes.length; i += step) out += String.fromCharCode(...bytes.slice(i, i + step));
  return out;
}

function latin1ToBytes(value = "") {
  const bytes = new Uint8Array(value.length);
  for (let i = 0; i < value.length; i++) bytes[i] = value.charCodeAt(i) & 255;
  return bytes;
}

function decodeXmlEntities(value = "") {
  return value
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, "\"")
    .replace(/&apos;/g, "'")
    .replace(/&#x([0-9a-f]+);/gi, (_, hex) => String.fromCharCode(parseInt(hex, 16)))
    .replace(/&#(\d+);/g, (_, code) => String.fromCharCode(Number(code)));
}

function documentExtractionQuality(text = "") {
  const clean = cleanText(text);
  if (clean.length > 1800) return 90;
  if (clean.length > 800) return 75;
  if (clean.length > 240) return 55;
  if (clean.length > 80) return 35;
  return 10;
}

function extractDocumentTags(docs) {
  return [...new Set(docs.flatMap(doc => doc.tags || inferTagsFromText(`${doc.name} ${doc.text || ""}`)))].slice(0, 10);
}

function buildDocumentInsights(docs) {
  if (!docs.length) return "";
  const tags = extractDocumentTags(docs);
  const signals = [...new Set(docs.flatMap(doc => doc.projectSignals || []))].slice(0, 6);
  const funding = extractFundingTypes(docs);
  const criteria = extractWinningCriteria(docs).slice(0, 6);
  const readable = docs.filter(doc => doc.text && doc.text.length > 80).length;
  const avgQuality = docs.length ? Math.round(docs.reduce((total, doc) => total + Number(doc.extractionQuality || documentExtractionQuality(doc.text)), 0) / docs.length) : 0;
  const parts = [`${docs.length} documenti collegati`, `${readable} leggibili automaticamente`];
  if (avgQuality) parts.push(`qualità media lettura ${avgQuality}%`);
  if (tags.length) parts.push(`temi rilevati: ${tags.join(", ")}`);
  if (signals.length) parts.push(`segnali progettuali: ${signals.join(", ")}`);
  if (funding.length) parts.push(`finanziamenti storici rilevati: ${funding.join(", ")}`);
  if (criteria.length) parts.push(`criteri vincenti probabili: ${criteria.join(", ")}`);
  return parts.join(". ");
}

function clientDocumentProfile(client, grant = null) {
  const docs = client.documentFiles || [];
  const hay = `${client.documents || ""} ${client.statuteStatus || ""} ${client.financialReports || ""} ${client.registryRunts || ""} ${client.registryRasd || ""} ${client.registryOther || ""} ${client.rasdNumber || ""} ${client.sportBody || ""} ${client.projectHistory || ""} ${client.fundedProjects || ""} ${client.reportingHistory || ""} ${docs.map(doc => `${doc.name} ${doc.text || ""}`).join(" ")}`.toLowerCase();
  const checks = [
    { key: "statuto", label: "Statuto", required: true, re: /statuto|atto costitutivo|riforma sport|codice del terzo settore/ },
    { key: "rendiconti", label: "Bilancio/rendiconto", required: true, re: /bilancio|rendiconto|rendicontazione|conto economico|bilancio sociale/ },
    { key: "registri", label: "RUNTS/RASD o registri", required: isSportEntity(client.type) || /aps|odv|ets/i.test(client.type), re: /runts|rasd|registro nazionale|registro unico|iscritt|affiliazione|coni|sport e salute/ },
    { key: "progetti", label: "Relazione/progetti", required: Boolean(grant), re: /relazione|progetto|formulario|iniziativa|attività realizzata|beneficiari|risultati/ },
    { key: "budget", label: "Budget/preventivo", required: Boolean(grant?.cofunding || grant?.amount), re: /budget|preventivo|piano finanziario|quadro economico|cofinanziamento|risorse proprie/ },
    { key: "partner", label: "Partner/accordi", required: grant?.complexity === "Alta", re: /partner|partenariat|accordo|protocollo|lettera di adesione|rete|co-progettazione|coprogettazione/ },
    { key: "amministrativi", label: "DURC/assicurazioni/DSAN", required: false, re: /durc|dsan|assicuraz|dichiarazione sostitutiva|privacy|tracciabilità/ },
    { key: "finanziamenti", label: "Storico finanziamenti", required: false, re: /finanziat|contributo|bando vinto|graduatoria|ammesso al contributo|erogazione/ }
  ];
  const required = checks.filter(check => check.required);
  const found = checks.filter(check => check.re.test(hay)).map(check => check.label);
  const missingRequired = required.filter(check => !check.re.test(hay)).map(check => check.label);
  const requiredScore = required.length ? Math.round(((required.length - missingRequired.length) / required.length) * 75) : 75;
  const bonus = Math.min(25, found.filter(label => !required.some(check => check.label === label)).length * 6 + Math.min(10, docs.length * 2));
  const score = Math.max(0, Math.min(100, requiredScore + bonus));
  const label = score >= 80 ? "Fascicolo pronto" : score >= 55 ? "Fascicolo utilizzabile, da integrare" : "Fascicolo da completare";
  return { score, label, found, missing: missingRequired, totalDocs: docs.length };
}

function inferTagsFromText(text = "") {
  const lower = text.toLowerCase();
  return TAGS.filter(tag => lower.includes(tag)).slice(0, 12);
}

function inferProjectSignals(text = "") {
  const lower = text.toLowerCase();
  const signals = [];
  if (/rendicont|bilancio|budget|fatturato|conto economico/.test(lower)) signals.push("capacità rendicontativa");
  if (/partner|partenariat|accordo|protocollo|rete/.test(lower)) signals.push("rete partner");
  if (/scuola|student|educativ|formazione/.test(lower)) signals.push("esperienza educativa");
  if (/disabil|inclus|fragil|welfare|sociale/.test(lower)) signals.push("impatto sociale");
  if (/sport|impiant|campionat|torneo|atlet/.test(lower)) signals.push("esperienza sportiva");
  if (/evento|festival|manifestazione/.test(lower)) signals.push("gestione eventi");
  return signals;
}

function inferFundingSignals(text = "") {
  const lower = text.toLowerCase();
  const publicSignals = matchSignals(lower, [
    ["contributo pubblico", /contribut[oi]\s+pubblic/],
    ["ministero/dipartimento", /ministero|dipartimento|presidenza del consiglio/],
    ["regione/comune", /regione|comune|provincia|città metropolitana|municipio/],
    ["fondi europei", /unione europea|commissione europea|erasmus|fse|fesr|pnrr|next generation eu|cerv|eacea/],
    ["sport e salute/CONI", /sport e salute|coni|dipartimento per lo sport/]
  ]);
  const privateSignals = matchSignals(lower, [
    ["fondazione privata", /fondazione|ente filantropico|impresa sociale con i bambini/],
    ["sponsor/CSR", /sponsor|sponsorizz|csr|responsabilità sociale|corporate/],
    ["donazione", /donazion|erogazione liberale|liberalità|raccolta fondi|fundraising/],
    ["banca/impresa", /banca|istituto di credito|azienda|impresa|società benefit/]
  ]);
  const criteria = matchSignals(lower, [
    ["impatto sociale misurabile", /impatto|indicatori|outcome|risultati attesi|monitoraggio/],
    ["partenariato forte", /partenariat|rete|accordo|protocollo|co-progettazione|coprogettazione/],
    ["cofinanziamento sostenibile", /cofinanziamento|quota a carico|risorse proprie|sostenibilità economica/],
    ["innovazione", /innovazion|sperimentazion|modello replicabile|scalabil/],
    ["inclusione e fragilità", /inclusion|fragil|disabil|povertà|welfare|marginalità/],
    ["esperienza pregressa", /esperienza|progetti realizzati|curriculum|track record|storico/],
    ["rendicontazione solida", /rendicont|bilancio|fatture|giustificativi|audit|controllo/],
    ["premialità o graduatoria", /punteggio|graduatoria|premialità|criteri di valutazione|valutazione/]
  ]);

  let fundingType = "Non rilevato";
  if (publicSignals.length && privateSignals.length) fundingType = "Finanziamento misto pubblico/privato";
  else if (publicSignals.length) fundingType = "Finanziamento pubblico";
  else if (privateSignals.length) fundingType = "Finanziamento privato";

  return {
    fundingType,
    fundingEvidence: [...new Set([...publicSignals, ...privateSignals])].slice(0, 8),
    winningCriteria: [...new Set(criteria)].slice(0, 8)
  };
}

function matchSignals(text, rules) {
  return rules.filter(([, re]) => re.test(text)).map(([label]) => label);
}

function extractFundingTypes(docs) {
  return [...new Set(docs.map(doc => doc.fundingType).filter(type => type && type !== "Non rilevato"))];
}

function extractWinningCriteria(docs) {
  return [...new Set(docs.flatMap(doc => doc.winningCriteria || []))];
}

function buildFundingInsights(docs) {
  const types = extractFundingTypes(docs);
  const criteria = extractWinningCriteria(docs).slice(0, 8);
  const evidence = [...new Set(docs.flatMap(doc => doc.fundingEvidence || []))].slice(0, 8);
  const parts = [];
  if (types.length) parts.push(`Tipologie rilevate: ${types.join(", ")}`);
  if (evidence.length) parts.push(`indizi: ${evidence.join(", ")}`);
  if (criteria.length) parts.push(`criteri probabili: ${criteria.join(", ")}`);
  return parts.join(". ");
}

function buildClientSuggestionsFromDocuments(docs) {
  const text = cleanText(docs.map(doc => `${doc.name} ${doc.text || ""}`).join(" "));
  const lower = text.toLowerCase();
  const tags = extractDocumentTags(docs);
  const funding = buildFundingInsights(docs);
  const regions = ["Abruzzo","Basilicata","Calabria","Campania","Emilia-Romagna","Friuli-Venezia Giulia","Lazio","Liguria","Lombardia","Marche","Molise","Piemonte","Puglia","Sardegna","Sicilia","Toscana","Trentino-Alto Adige","Umbria","Valle d'Aosta","Veneto"];
  const region = regions.find(r => lower.includes(r.toLowerCase())) || "";
  const area = region || extractRegex(text, /\b(?:comune|provincia|territorio|sede)\s+(?:di|del|della)?\s*([A-ZÀ-Ý][A-Za-zÀ-ÿ' -]{2,40})/);
  const type = inferLegalTypeFromText(text);
  const name = extractEntityNameFromText(text);
  const legalAddress = extractRegex(text, /\b(?:sede legale|con sede in|sede)\s+(?:in|a)?\s*([^.;\n]{8,90})/i);
  const city = extractRegex(text, /\b(?:comune di|città di|sede in|residente in)\s+([A-ZÀ-Ý][A-Za-zÀ-ÿ' -]{2,40})/);
  const province = extractRegex(text, /\b(?:provincia di|prov\.)\s*([A-ZÀ-Ý]{2}|[A-ZÀ-Ý][A-Za-zÀ-ÿ' -]{2,40})/);
  const vat = extractRegex(text, /\b(?:codice fiscale|c\.f\.|cf|partita iva|p\.iva)\s*(?:n\.?|:)?\s*([A-Z0-9]{8,16})/i);
  const founded = extractRegex(text, /\b(?:costituita|costituito|fondata|fondato)\s+(?:il\s+)?(?:\d{1,2}[\/.-]\d{1,2}[\/.-])?(19\d{2}|20\d{2})/i);
  const rasdNumber = extractRegex(text, /\b(?:rasd|registro nazionale)[^0-9A-Z]{0,30}(?:n\.?|numero|codice)?\s*([A-Z0-9\-/]{4,24})/i);
  const rasdName = name && /rasd|registro nazionale.*sport|registro.*attività sportive/.test(lower) ? name : "";
  const sportBody = extractSportBody(text);
  const sportActivities = extractSportActivities(text);
  const activities = extractBestSentences(text, ["attività","missione","finalità","sport","sociale","educazione","inclusione","servizi","progetto"], 3);
  const publicPartners = extractBestSentences(text, ["comune","regione","ministero","scuola","asl","università","ente pubblico"], 2);
  const privatePartners = extractBestSentences(text, ["fondazione","sponsor","azienda","impresa","banca","donazione","csr"], 2);
  const projectHistory = extractBestSentences(text, ["progetto realizzato","iniziativa","edizione","partecipanti","beneficiari","risultati"], 3);
  const fundedProjects = extractBestSentences(text, ["finanziato","contributo","bando vinto","graduatoria","ammesso al contributo","erogazione"], 3);
  const reportingHistory = extractBestSentences(text, ["rendicontato","rendicontazione","saldo","fatture","giustificativi","bilancio"], 2);
  const documents = inferDocumentInventory(lower).join(", ");
  return {
    name,
    type,
    legalAddress,
    city,
    province,
    region,
    area,
    vat,
    founded,
    capacity: inferCapacityFromText(lower),
    statuteStatus: lower.includes("statuto") ? (lower.includes("riforma dello sport") || lower.includes("riforma sport") ? "Aggiornato Riforma Sport" : lower.includes("codice del terzo settore") || lower.includes("runts") ? "Aggiornato CTS/RUNTS" : "Disponibile") : "",
    financialReports: /bilancio sociale/.test(lower) ? "Bilancio sociale disponibile" : /ultimi\s+3|tre\s+anni/.test(lower) ? "Ultimi 3 anni disponibili" : /ultimi\s+2|due\s+anni/.test(lower) ? "Ultimi 2 anni disponibili" : /bilancio|rendiconto/.test(lower) ? "Ultimo anno disponibile" : "",
    registryRunts: lower.includes("runts") ? "Iscritto" : "",
    registryRasd: /rasd|registro nazionale.*sport|registro.*attività sportive/.test(lower) ? "Iscritto" : "",
    rasdName,
    rasdNumber,
    sportBody,
    sportActivities,
    documents,
    activities,
    publicPartners,
    privatePartners,
    projectHistory,
    fundedProjects,
    reportingHistory,
    summary: [tags.length ? `tag suggeriti: ${tags.join(", ")}` : "", funding ? `finanziamenti: ${funding}` : "", documents ? `documenti riconosciuti: ${documents}` : ""].filter(Boolean).join(". ")
  };
}

function inferLegalTypeFromText(text) {
  const lower = text.toLowerCase();
  const rules = [
    [/ssd\s*a\.?\s*r\.?l\.?|società sportiva dilettantistica.*responsabilità limitata/, "SSD a r.l. - Società Sportiva Dilettantistica a responsabilità limitata"],
    [/\basd\b|associazione sportiva dilettantistica/, "ASD - Associazione Sportiva Dilettantistica"],
    [/\bssd\b|società sportiva dilettantistica/, "SSD - Società Sportiva Dilettantistica"],
    [/\baps\b|associazione di promozione sociale/, "APS - Associazione di Promozione Sociale"],
    [/\bodv\b|organizzazione di volontariato/, "ODV - Organizzazione di Volontariato"],
    [/\bets\b|ente del terzo settore/, "ETS - Ente del Terzo Settore"],
    [/\beps\b|ente di promozione sportiva/, "EPS - Ente di Promozione Sportiva"],
    [/cooperativa sociale.*tipo a/, "Cooperativa sociale tipo A"],
    [/cooperativa sociale.*tipo b/, "Cooperativa sociale tipo B"],
    [/impresa sociale/, "Impresa sociale"],
    [/fondazione di comunità/, "Fondazione di comunità"],
    [/fondazione/, "Fondazione ETS"],
    [/pro loco/, "Pro Loco"],
    [/parrocchia|oratorio/, "Parrocchia / Oratorio"]
  ];
  return rules.find(([re]) => re.test(lower))?.[1] || "";
}

function extractEntityNameFromText(text) {
  const patterns = [
    /\b(?:associazione sportiva dilettantistica|asd|società sportiva dilettantistica|ssd|associazione|ente|fondazione)\s+["“]?([A-ZÀ-Ý][A-Za-zÀ-ÿ0-9'& .-]{3,70})["”]?/i,
    /\bdenominazione\s*(?:sociale)?\s*[:\-]\s*["“]?([^.;\n]{4,80})/i,
    /\bnome\s+ente\s*[:\-]\s*["“]?([^.;\n]{4,80})/i
  ];
  for (const re of patterns) {
    const value = extractRegex(text, re);
    if (value) return cleanText(value).replace(/["“”]/g, "");
  }
  return "";
}

function extractSportBody(text) {
  const lower = text.toLowerCase();
  const bodies = [
    ["UISP", /uisp/],
    ["CSI", /\bcsi\b|centro sportivo italiano/],
    ["ACSI", /acsi/],
    ["AICS", /aics/],
    ["ASI", /\basi\b|associazioni sportive sociali italiane/],
    ["CSEN", /csen/],
    ["OPES", /opes/],
    ["PGS", /\bpgs\b/],
    ["FIGC", /figc|federazione italiana giuoco calcio/],
    ["FIN", /\bfin\b|federazione italiana nuoto/],
    ["FIP", /\bfip\b|federazione italiana pallacanestro/],
    ["FIPAV", /fipav|pallavolo/],
    ["FIDAL", /fidal|atletica/],
    ["FITP", /fitp|tennis|padel/],
    ["CONI", /\bconi\b/],
    ["Sport e Salute", /sport e salute/]
  ];
  return bodies.filter(([, re]) => re.test(lower)).map(([label]) => label).slice(0, 4).join(", ");
}

function extractSportActivities(text) {
  const lower = text.toLowerCase();
  const activities = ["calcio","pallavolo","basket","pallacanestro","nuoto","danza","ginnastica","atletica","tennis","padel","arti marziali","judo","karate","ciclismo","running","fitness","yoga","rugby","baseball","softball","sport inclusivo"];
  return activities.filter(activity => lower.includes(activity)).slice(0, 8).join(", ");
}

function inferCapacityFromText(lower) {
  if (/bilancio sociale|audit|certificat|pnrr|europeo|partenariat|capofila/.test(lower)) return "Alta";
  if (/bilancio|rendicont|partner|dipendent|collaborator|volontari/.test(lower)) return "Media";
  return "";
}

function inferDocumentInventory(lower) {
  return matchSignals(lower, [
    ["statuto", /statuto/],
    ["atto costitutivo", /atto costitutivo/],
    ["bilancio/rendiconto", /bilancio|rendiconto/],
    ["relazione progetto", /relazione|progetto|presentazione/],
    ["affiliazione sportiva", /affiliazione|federazione|eps|coni/],
    ["assicurazioni", /assicuraz/],
    ["DURC", /durc/],
    ["5x1000", /5x1000|cinque per mille/]
  ]);
}

function extractRegex(text, regex) {
  const match = text.match(regex);
  return match ? cleanText(match[1]) : "";
}

function formatBytes(bytes = 0) {
  if (!bytes) return "0 KB";
  if (bytes < 1024 * 1024) return `${Math.max(1, Math.round(bytes / 1024))} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

function setClientForm(c) {
  selectedClientId = c?.id || null;
  clientTags = c?.tags || [];
  clientDocs = c?.documentFiles || [];
  $("clientFormTitle").textContent = c ? "Modifica profilo cliente" : "Nuovo profilo cliente";
  ["name","legalAddress","city","province","region","operationalSite","area","contact","contactInfo","website","vat","founded","budget","cofunding","staff","volunteers","spaces","registryOther","documents","rasdName","rasdNumber","sportBody","sportActivities","rasdLastCheck","activities","strengths","weaknesses","publicPartners","privatePartners","projectHistory","fundedProjects","reportingHistory","goals","notes"].forEach(k => $("c_" + k).value = c?.[k] || "");
  ["type","geoScope","status","capacity","statuteStatus","financialReports","registryRunts","registryRasd","rasdCheckStatus"].forEach(k => $("c_" + k).value = c?.[k] || $("c_" + k).options[0].value);
  $("c_priority").value = c?.priority || 7;
  $("priorityOut").textContent = $("c_priority").value;
  renderClientTagPickers();
  renderClientDocuments();
  renderRasdCheckPanel(c || getClientForm());
  renderClientPreview(c);
  renderClients();
}

