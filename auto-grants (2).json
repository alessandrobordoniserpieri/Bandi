    city: $("c_city").value.trim(), province: $("c_province").value.trim(), region: $("c_region").value.trim(),
    operationalSite: $("c_operationalSite").value.trim(), area: $("c_area").value.trim(), geoScope: $("c_geoScope").value,
    status: $("c_status").value, contact: $("c_contact").value.trim(), contactInfo: $("c_contactInfo").value.trim(),
    website: $("c_website").value.trim(), vat: $("c_vat").value.trim(), founded: $("c_founded").value.trim(),
    capacity: $("c_capacity").value, priority: Number($("c_priority").value), budget: $("c_budget").value.trim(),
    cofunding: $("c_cofunding").value.trim(), staff: $("c_staff").value.trim(), volunteers: $("c_volunteers").value.trim(),
    statuteStatus: $("c_statuteStatus").value, financialReports: $("c_financialReports").value,
    registryRunts: $("c_registryRunts").value, registryRasd: $("c_registryRasd").value, registryOther: $("c_registryOther").value.trim(),
    rasdName: $("c_rasdName").value.trim(), rasdNumber: $("c_rasdNumber").value.trim(),
    sportBody: $("c_sportBody").value.trim(), sportActivities: $("c_sportActivities").value.trim(),
    rasdCheckStatus: $("c_rasdCheckStatus").value, rasdLastCheck: $("c_rasdLastCheck").value,
    spaces: $("c_spaces").value.trim(), documents: $("c_documents").value.trim(), documentFiles: clientDocs,
    documentInsights: buildDocumentInsights(clientDocs), documentTags: extractDocumentTags(clientDocs),
    fundingInsights: buildFundingInsights(clientDocs), fundingTypes: extractFundingTypes(clientDocs), winningCriteria: extractWinningCriteria(clientDocs),
    tags: clientTags,
    activities: $("c_activities").value.trim(), strengths: $("c_strengths").value.trim(), weaknesses: $("c_weaknesses").value.trim(),
    publicPartners: $("c_publicPartners").value.trim(), privatePartners: $("c_privatePartners").value.trim(),
    projectHistory: $("c_projectHistory").value.trim(), fundedProjects: $("c_fundedProjects").value.trim(),
    reportingHistory: $("c_reportingHistory").value.trim(), goals: $("c_goals").value.trim(), notes: $("c_notes").value.trim()
  });
}

function renderClientPreview(c) {
  const el = $("clientPreview");
  if (!c) { el.className = "empty"; el.innerHTML = "Nessun cliente selezionato."; return; }
  el.className = "";
  const completeness = profileCompleteness(c);
  const rasdAudit = buildRasdAudit(c);
  const docProfile = clientDocumentProfile(c);
  el.innerHTML = `<div class="profilebox"><div><h2>${esc(c.name || "Senza nome")}</h2><p class="hint">${esc(c.type)} · ${esc([c.city, c.province, c.region].filter(Boolean).join(" / ") || c.area || "-")} · ${esc(c.status)}</p><div class="chips">${(c.tags || []).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div></div><div class="fact"><strong>Qualità profilo</strong><div class="score-lg">${completeness}%</div><div class="scorebar"><span style="width:${completeness}%"></span></div></div></div><div class="three section"><div class="fact"><strong>Sede e territorio</strong>${esc(c.legalAddress || "-")}<p>${esc([c.city, c.province, c.region].filter(Boolean).join(" / ") || "-")}</p></div><div class="fact"><strong>Registri</strong>RUNTS: ${esc(c.registryRunts || "-")}<p>RASD: ${esc(c.registryRasd || "-")}</p><p>${esc(c.rasdCheckStatus || "Non avviato")}</p></div><div class="fact"><strong>Statuto e rendiconti</strong>${esc(c.statuteStatus || "-")}<p>${esc(c.financialReports || "-")}</p></div></div><div class="three section"><div class="fact"><strong>Capacità</strong>${esc(c.capacity)}</div><div class="fact"><strong>Cofinanziamento</strong>${esc(c.cofunding || "-")}</div><div class="fact"><strong>Documenti</strong>${esc(c.documents || "-")}<p>${esc((c.documentFiles || []).length)} file caricati</p></div></div><div class="section"><div class="section-title">Prontezza documentale</div><div class="profilebox"><div class="fact"><strong>${esc(docProfile.label)}</strong><div class="score-lg">${docProfile.score}%</div><div class="scorebar"><span style="width:${docProfile.score}%"></span></div></div><div><div class="reason">${docProfile.found.map(x => `<span class="plus">${esc(x)}</span>`).join("")}${docProfile.missing.map(x => `<span class="minus">Manca: ${esc(x)}</span>`).join("")}</div></div></div></div><div class="section"><div class="section-title">Controllo RASD</div><div class="metric-grid"><div class="fact"><strong>Denominazione</strong><p>${esc(c.rasdName || c.name || "-")}</p></div><div class="fact"><strong>Codice RASD</strong><p>${esc(c.rasdNumber || "-")}</p></div><div class="fact"><strong>Organismo sportivo</strong><p>${esc(c.sportBody || "-")}</p></div><div class="fact"><strong>Discipline</strong><p>${esc(c.sportActivities || "-")}</p></div></div>${renderRasdAuditHtml(rasdAudit)}</div><div class="two section"><div class="fact"><strong>Attività</strong><p>${esc(c.activities || "-")}</p></div><div class="fact"><strong>Progetti e rendicontazioni</strong><p>${esc(c.projectHistory || "-")}</p><p>${esc(c.fundedProjects || "")}</p><p>${esc(c.reportingHistory || "")}</p></div><div class="fact"><strong>Obiettivi</strong><p>${esc(c.goals || "-")}</p></div></div>${c.documentInsights ? `<div class="section fact"><strong>Analisi documentale</strong><p>${esc(c.documentInsights)}</p><div class="chips">${(c.documentTags || []).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div></div>` : ""}${c.fundingInsights ? `<div class="section fact"><strong>Finanziamenti storici rilevati</strong><p>${esc(c.fundingInsights)}</p><div class="chips">${(c.fundingTypes || []).map(t => `<span class="chip">${esc(t)}</span>`).join("")}${(c.winningCriteria || []).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div></div>` : ""}`;
}

function buildRasdAudit(c) {
  const sportEntity = isSportEntity(c.type);
  const text = `${clientDocs.map(doc => `${doc.name} ${doc.text || ""}`).join(" ")} ${c.documents || ""} ${c.registryOther || ""}`.toLowerCase();
  const ok = [];
  const missing = [];
  const warnings = [];
  if (!sportEntity) {
    return { status: "Non necessario", ok: ["Il profilo non risulta ASD/SSD o soggetto sportivo"], missing: [], warnings: [] };
  }
  c.registryRasd === "Iscritto" ? ok.push("Iscrizione RASD indicata") : missing.push("Confermare iscrizione RASD");
  (c.rasdName || c.name) ? ok.push("Denominazione disponibile") : missing.push("Denominazione ente");
  c.rasdNumber ? ok.push("Codice/numero RASD inserito") : warnings.push("Codice RASD non presente nei campi");
  c.sportBody ? ok.push("Organismo sportivo affiliante indicato") : missing.push("Organismo sportivo affiliante FSN/DSA/EPS");
  c.sportActivities ? ok.push("Discipline o attività sportive indicate") : missing.push("Discipline/attività sportive");
  /statuto/.test(text) || c.statuteStatus !== "Non verificato" ? ok.push("Statuto rilevato") : missing.push("Statuto aggiornato");
  /bilancio|rendiconto/.test(text) || !/non verificato|da ricostruire/i.test(c.financialReports) ? ok.push("Bilanci/rendiconti rilevati") : missing.push("Rendiconti o bilanci");
  /affiliazione|federazione|eps|coni|sport e salute|rasd/.test(text) ? ok.push("Indizi documentali sportivi presenti") : warnings.push("Nei documenti non emergono ancora affiliazione o iscrizione sportiva");
  const status = missing.length ? "Da completare" : warnings.length ? "Quasi completo" : "Completo";
  return { status, ok, missing, warnings };
}

function renderRasdAuditHtml(audit) {
  return `<div class="advice-list"><strong>Esito interno: ${esc(audit.status)}</strong>${audit.ok.map(x => `<span class="plus">${esc(x)}</span>`).join("")}${audit.missing.map(x => `<span class="minus">Manca: ${esc(x)}</span>`).join("")}${audit.warnings.map(x => `<span>${esc(x)}</span>`).join("")}</div>`;
}

function renderRasdCheckPanel(c) {
  const el = $("rasdCheckPanel");
  if (!el) return;
  const audit = buildRasdAudit(c);
  el.innerHTML = `${renderRasdAuditHtml(audit)}<p class="hint" style="margin-top:8px">Il confronto automatico usa i documenti caricati e i campi compilati. Per la conferma ufficiale apri il Registro RASD e riporta qui denominazione, codice, organismo sportivo e data controllo.</p>`;
}

function runRasdComparison(options = {}) {
  const c = getClientForm();
  const audit = buildRasdAudit(c);
  if (isSportEntity(c.type)) {
    $("c_rasdCheckStatus").value = audit.missing.length ? "Da verificare" : audit.warnings.length ? "Incongruenze" : "Corrisponde";
    if (!$("c_rasdLastCheck").value) $("c_rasdLastCheck").value = new Date().toISOString().slice(0, 10);
  }
  renderRasdCheckPanel(getClientForm());
  renderClientPreview(getClientForm());
  if (!options.silent) toast("Confronto RASD aggiornato");
}

function openRasdRegistry() {
  window.open("https://registro.sportesalute.eu/", "_blank", "noopener,noreferrer");
  if (!$("c_rasdLastCheck").value) $("c_rasdLastCheck").value = new Date().toISOString().slice(0, 10);
  if ($("c_rasdCheckStatus").value === "Non avviato") $("c_rasdCheckStatus").value = "Da verificare";
  renderRasdCheckPanel(getClientForm());
}

function isSportEntity(type = "") {
  return /asd|ssd|sport|eps|fsn|dsa|coni|rasd/i.test(type);
}

function setGrantForm(g) {
  selectedGrantId = g?.id || null;
  grantTags = g?.tags || [];
  grantTypes = g?.eligibleTypes || [];
  $("grantFormTitle").textContent = g ? "Modifica bando" : "Nuovo bando";
  ["title","provider","url","deadline","area","amount","cofunding","requirements","expenses","summary","notes"].forEach(k => $("g_" + k).value = g?.[k] || "");
  ["status","geoScope","minCapacity","complexity"].forEach(k => $("g_" + k).value = g?.[k] || $("g_" + k).options[0].value);
  $("g_source").value = g?.sourceId || "";
  renderTagPicker("grantTags", TAGS, grantTags, next => { grantTags = next; renderGrantTagPickers(); });
  renderTagPicker("grantTypes", LEGAL_TYPES, grantTypes, next => { grantTypes = next; renderGrantTagPickers(); });
  renderGrantPreview(g);
  renderGrants();
}

function renderGrantTagPickers() {
  renderTagPicker("grantTags", TAGS, grantTags, next => { grantTags = next; renderGrantTagPickers(); });
  renderTagPicker("grantTypes", LEGAL_TYPES, grantTypes, next => { grantTypes = next; renderGrantTagPickers(); });
}

function getGrantForm() {
  return normalizeGrant({
    id: selectedGrantId || uid("g"), title: $("g_title").value.trim(), provider: $("g_provider").value.trim(),
    sourceId: $("g_source").value, url: $("g_url").value.trim(), status: $("g_status").value,
    deadline: $("g_deadline").value, area: $("g_area").value.trim(), geoScope: $("g_geoScope").value,
    amount: $("g_amount").value.trim(), cofunding: $("g_cofunding").value.trim(), eligibleTypes: grantTypes,
    tags: grantTags, minCapacity: $("g_minCapacity").value, complexity: $("g_complexity").value,
    requirements: $("g_requirements").value.trim(), expenses: $("g_expenses").value.trim(),
    summary: $("g_summary").value.trim(), notes: $("g_notes").value.trim()
  });
}

function renderGrantPreview(g) {
  const el = $("grantPreview");
  if (!g) { el.className = "empty"; el.innerHTML = "Nessun bando selezionato."; return; }
  el.className = "";
  const source = data.sources.find(s => s.id === g.sourceId);
  const officialLink = g.url ? `<a href="${esc(g.url)}" target="_blank" rel="noreferrer">Apri scheda ufficiale</a>` : "";
  const comparison = historicalGrantProfile(g);
  const quality = grantDataQuality(g);
  const extraction = grantExtractionProfile(g);
  const similarHistory = renderSimilarClosedGrants(g);
  el.innerHTML = `<div class="profilebox"><div><h2>${esc(g.title || "Senza titolo")}</h2><p class="hint">${esc(g.provider || "-")} · ${esc(normalizedGrantStatus(g))}</p>${deadlineBadge(g)}${qualityBadge(quality)}<div class="chips" style="margin-top:10px">${(g.tags || []).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div></div><div class="fact"><strong>Qualità scheda</strong><div class="score-lg">${quality.score}%</div><div class="scorebar"><span style="width:${quality.score}%"></span></div><span class="muted">${esc(quality.label)}</span></div></div><div class="three section"><div class="fact"><strong>Contributo</strong>${esc(g.amount || "-")}<p>Cofin. ${esc(g.cofunding || "-")}</p></div><div class="fact"><strong>Territorio</strong>${esc(g.area || "-")}</div><div class="fact"><strong>Fonte</strong>${esc(source?.name || g.provider || "-")}<p>${officialLink}</p></div></div><div class="section fact"><strong>Riassunto opportunità</strong><p>${esc(g.summary || "-")}</p></div><div class="section"><div class="section-title">Dati estratti automaticamente</div><div class="metric-grid">${extraction.metrics.map(f => `<div class="fact"><strong>${esc(f.label)}</strong><p>${esc(f.value || "-")}</p></div>`).join("")}</div>${quality.missing.length ? `<div class="advice-list">${quality.missing.map(x => `<span>Da completare: ${esc(x)}</span>`).join("")}</div>` : ""}</div><div class="two section"><div class="fact"><strong>Chi può partecipare</strong><p>${esc(g.beneficiaries || g.eligibleTypes?.join(", ") || "-")}</p></div><div class="fact"><strong>Cosa richiede il bando</strong><p>${esc(g.requirements || "-")}</p></div><div class="fact"><strong>Spese e attività finanziabili</strong><p>${esc(g.expenses || "-")}</p></div><div class="fact"><strong>Scadenze, importi e procedura</strong><p>${esc(g.detail || "-")}</p></div></div><div class="section"><div class="section-title">${isClosedGrant(g) ? "Scheda storica per confronto" : "Specifiche da confrontare"}</div><p class="hint">${esc(comparison.summary)}</p><div class="comparison-grid">${comparison.facts.map(f => `<div class="fact"><strong>${esc(f.label)}</strong><p>${esc(f.value || "-")}</p></div>`).join("")}</div></div>${similarHistory}`;
}

function historicalGrantProfile(g) {
  const criteria = inferGrantEvaluationCriteria(g);
  const documents = inferGrantRequestedDocuments(g);
  return {
    summary: isClosedGrant(g)
      ? "Questo bando resta nello storico: l'app lo usa come base di paragone per riconoscere bandi futuri simili, requisiti ricorrenti, importi, destinatari e criteri di valutazione."
      : "Queste specifiche vengono salvate per confrontare il bando con profili cliente, progetti caricati e bandi futuri simili.",
    facts: [
      { label: "Stato operativo", value: normalizedGrantStatus(g) },
      { label: "Scadenza domanda", value: g.deadline ? `${new Date(g.deadline + "T12:00:00").toLocaleDateString("it-IT")} · ${deadlineLabel(g.deadline)}` : "non rilevata" },
      { label: "Beneficiari", value: g.beneficiaries || (g.eligibleTypes || []).join(", ") },
      { label: "Criteri probabili", value: criteria.join(", ") || "da estrarre dalla scheda ufficiale" },
      { label: "Documenti richiesti", value: documents.join(", ") || "da verificare sul testo ufficiale" },
      { label: "Ambiti confronto", value: (g.tags || []).join(", ") || "tema non classificato" }
    ]
  };
}

function renderSimilarClosedGrants(g) {
  const similar = similarClosedGrants(g).slice(0, 3);
  if (!similar.length) return "";
  return `<div class="section"><div class="section-title">Bandi storici simili</div><div class="comparison-grid">${similar.map(item => `<button class="source-card" type="button" onclick="openGrantFromMatch('${item.grant.id}')"><strong>${esc(item.grant.title)}</strong><p class="hint">${esc(item.grant.provider || "-")} · ${esc(deadlineLabel(item.grant.deadline))}</p><span class="inline-score">similarità ${item.score}/100</span><div class="chips">${(item.sharedTags || []).slice(0,4).map(t => `<span class="chip">${esc(t)}</span>`).join("")}</div></button>`).join("")}</div></div>`;
}

function similarClosedGrants(g) {
  return data.grants
    .filter(other => other.id !== g.id && isClosedGrant(other))
    .map(other => {
      const sharedTags = (g.tags || []).filter(tag => (other.tags || []).includes(tag));
      const sharedTypes = (g.eligibleTypes || []).filter(type => (other.eligibleTypes || []).some(otherType => hasCompatibleLegalType(type, [otherType])));
      const area = textOverlap(g.area, other.area) ? 12 : 0;
      const criteria = inferGrantEvaluationCriteria(g).filter(c => inferGrantEvaluationCriteria(other).some(o => textOverlap(c, o) || c === o)).length * 7;
      const score = Math.min(100, sharedTags.length * 14 + sharedTypes.length * 10 + area + criteria);
      return { grant: other, score, sharedTags };
    })
    .filter(item => item.score >= 18)
    .sort((a, b) => b.score - a.score);
}

function grantDataQuality(g) {
  const checks = [
    ["titolo", g.title],
    ["ente erogatore", g.provider],
    ["URL ufficiale", g.url],
    ["scadenza", g.deadline],
    ["territorio", g.area],
    ["importo", g.amount],
    ["beneficiari", g.beneficiaries || (g.eligibleTypes || []).length],
    ["requisiti", g.requirements],
    ["spese ammissibili", g.expenses],
    ["sintesi", g.summary],
    ["procedura", g.detail],
    ["criteri di valutazione", inferGrantEvaluationCriteria(g).length],
    ["documenti richiesti", inferGrantRequestedDocuments(g).length]
  ];
  const filled = checks.filter(([, value]) => Array.isArray(value) ? value.length : String(value || "").trim()).length;
  const score = Math.round((filled / checks.length) * 100);
  const missing = checks.filter(([, value]) => !(Array.isArray(value) ? value.length : String(value || "").trim())).map(([label]) => label).slice(0, 6);
  const label = score >= 78 ? "Alta affidabilità dati" : score >= 52 ? "Scheda utilizzabile, da integrare" : "Scheda parziale, serve verifica";
  return { score, missing, label };
}

function qualityBadge(quality) {
  const cls = quality.score >= 78 ? "high" : quality.score >= 52 ? "mid" : "low";
  return `<span class="quality-pill ${cls}">Qualità dati ${quality.score}%</span>`;
}

function grantExtractionProfile(g) {
  const criteria = inferGrantEvaluationCriteria(g);
  const documents = inferGrantRequestedDocuments(g);
  return {
    metrics: [
      { label: "Forme ammesse", value: (g.eligibleTypes || []).join(", ") || "non estratte" },
      { label: "Criteri rilevati", value: criteria.join(", ") || "non estratti" },
      { label: "Documenti richiesti", value: documents.join(", ") || "non estratti" },
      { label: "Ambiti", value: (g.tags || []).join(", ") || "non classificati" }
    ]
  };
}

function setSourceForm(s) {
  selectedSourceId = s?.id || null;
  $("sourceFormTitle").textContent = s ? "Modifica fonte" : "Nuova fonte";
  ["name","url","lastCheck","notes"].forEach(k => $("s_" + k).value = s?.[k] || "");
  ["type","frequency"].forEach(k => $("s_" + k).value = s?.[k] || $("s_" + k).options[0].value);
  renderSources();
}

function getSourceForm() {
  return normalizeSource({
    id: selectedSourceId || uid("s"), name: $("s_name").value.trim(), type: $("s_type").value,
    url: $("s_url").value.trim(), frequency: $("s_frequency").value, lastCheck: $("s_lastCheck").value,
    notes: $("s_notes").value.trim()
  });
}

function calculateMatch(client, grant) {
  let score = 0;
  const plus = [];
  const minus = [];

  const clientSignalTags = [...new Set([...(client.tags || []), ...(client.documentTags || [])])];
  const shared = clientSignalTags.filter(t => (grant.tags || []).includes(t));
  const tagMax = Math.max(3, grant.tags.length || clientSignalTags.length || 1);
  const tagScore = Math.min(32, Math.round((shared.length / tagMax) * 32));
  score += tagScore;
  shared.length ? plus.push(`${shared.length} tag coerenti`) : minus.push("pochi temi in comune");

  if (!grant.eligibleTypes.length || hasCompatibleLegalType(client.type, grant.eligibleTypes)) { score += 18; plus.push("forma giuridica ammessa"); }
  else { score -= 10; minus.push("forma giuridica non evidente"); }

  const clientTerritory = [client.city, client.province, client.region, client.area, client.operationalSite].filter(Boolean).join(" ");
  const areaHit = textOverlap(clientTerritory, grant.area) || grant.area.toLowerCase().includes("italia") || grant.geoScope === "Nazionale" || grant.geoScope === "Europeo";
  if (areaHit) { score += 14; plus.push("territorio compatibile"); }
  else { score -= 8; minus.push("territorio da verificare"); }

  const capacityGap = CAPACITY_SCORE[client.capacity] - CAPACITY_SCORE[grant.minCapacity];
  if (capacityGap >= 0) { score += 12; plus.push("capacità adeguata"); }
  else { score -= grant.complexity === "Alta" ? 12 : 6; minus.push("capacità sotto la soglia"); }

  if (client.publicPartners || client.privatePartners) { score += grant.complexity === "Alta" ? 10 : 6; plus.push("partnership utili"); }
  else if (grant.complexity !== "Bassa") { score -= 5; minus.push("partnership da costruire"); }

  const adminReadiness = [client.statuteStatus, client.financialReports, client.registryRunts, client.registryRasd, client.registryOther, client.rasdCheckStatus, client.rasdNumber, client.sportBody, client.documents].join(" ");
  if (/disponibile|aggiornato|iscritto|ultim|bilancio sociale|accredit/i.test(adminReadiness)) { score += 9; plus.push("assetto amministrativo documentato"); }
  else { minus.push("documenti non mappati"); }

  const documentProfile = clientDocumentProfile(client, grant);
  if (documentProfile.score >= 80) { score += 7; plus.push("fascicolo documentale pronto"); }
  else if (documentProfile.score >= 55) { score += 3; plus.push("fascicolo documentale utilizzabile"); }
  else { score -= 6; minus.push(`fascicolo incompleto${documentProfile.missing.length ? `: ${documentProfile.missing.slice(0,2).join(", ")}` : ""}`); }

  if (client.fundedProjects || client.reportingHistory) { score += 6; plus.push("storico progettuale utile"); }

  if ((client.documentFiles || []).length) {
    score += Math.min(8, (client.documentFiles || []).length * 2);
    plus.push("documenti caricati e analizzati");
  }

  if ((client.fundingTypes || []).length) {
    score += 5;
    plus.push("storico finanziamenti letto dai documenti");
  }

  const grantCriteria = inferGrantEvaluationCriteria(grant);
  const sharedCriteria = (client.winningCriteria || []).filter(c => grantCriteria.some(g => textOverlap(c, g) || c === g));
  if (sharedCriteria.length) {
    score += Math.min(8, sharedCriteria.length * 4);
    plus.push("criteri vincenti già presenti nello storico");
  }

  if (client.cofunding || /0\s*%|nessun/i.test(grant.cofunding)) { score += 5; plus.push("cofinanziamento gestibile"); }
  else if (grant.cofunding) { score -= 4; minus.push("cofinanziamento da valutare"); }

  const days = deadlineDays(grant.deadline);
  if (isClosedGrant(grant)) { score -= 30; minus.push("bando chiuso: resta solo storico"); }
  else if (Number.isFinite(days) && days < 8) { score -= 10; minus.push("scadenza molto vicina"); }
  else if (Number.isFinite(days) && days <= 45) { score += 4; plus.push("scadenza gestibile"); }
  else if (grant.status === "In uscita" || grant.status === "Ricorrente") { score += 6; plus.push("tempo per prepararsi"); }

  if (client.priority >= 8) score += 4;
  const finalScore = Math.max(0, Math.min(100, Math.round(score)));
  const breakdown = buildMatchBreakdown(client, grant, { tagScore, shared, areaHit, capacityGap, adminReadiness, sharedCriteria, days, documentProfile });
  const actions = buildMatchActions(client, grant, { areaHit, capacityGap, adminReadiness, sharedCriteria, days, documentProfile });
  return { score: finalScore, plus, minus, sharedTags: shared, breakdown, actions, client, grant };
}

function buildMatchBreakdown(client, grant, ctx) {
  const hasPartners = Boolean(client.publicPartners || client.privatePartners);
  const hasAdmin = /disponibile|aggiornato|iscritto|ultim|bilancio sociale|accredit/i.test(ctx.adminReadiness);
  const docScore = Math.round(((ctx.documentProfile?.score || 0) / 100) * 14);
  const historyScore = Math.min(21,
    (client.fundedProjects || client.reportingHistory ? 6 : 0) +
    Math.min(8, (client.documentFiles || []).length * 2) +
    ((client.fundingTypes || []).length ? 5 : 0) +
    Math.min(8, (ctx.sharedCriteria || []).length * 4)
  );
  const deadlineScore = isClosedGrant(grant) ? 0 : Number.isFinite(ctx.days) && ctx.days < 8 ? 3 : Number.isFinite(ctx.days) && ctx.days <= 45 ? 8 : 6;
  return [
    { label: "Temi", value: ctx.tagScore, max: 32, note: ctx.shared.length ? `${ctx.shared.length} temi condivisi` : "temi deboli" },
    { label: "Forma", value: (!grant.eligibleTypes.length || hasCompatibleLegalType(client.type, grant.eligibleTypes)) ? 18 : 0, max: 18, note: (!grant.eligibleTypes.length || hasCompatibleLegalType(client.type, grant.eligibleTypes)) ? "ammessa" : "da verificare" },
    { label: "Territorio", value: ctx.areaHit ? 14 : 3, max: 14, note: ctx.areaHit ? "compatibile" : "fuori area" },
    { label: "Capacità", value: ctx.capacityGap >= 0 ? 12 : Math.max(0, 12 + ctx.capacityGap * 4), max: 12, note: ctx.capacityGap >= 0 ? "adeguata" : "sotto soglia" },
    { label: "Partner", value: hasPartners ? (grant.complexity === "Alta" ? 10 : 6) : 0, max: 10, note: hasPartners ? "presenti" : "da costruire" },
    { label: "Documenti", value: Math.max(hasAdmin ? 6 : 0, docScore), max: 14, note: ctx.documentProfile?.label || (hasAdmin ? "assetto pronto" : "mancano prove") },
    { label: "Storico", value: historyScore, max: 21, note: historyScore ? "dati storici utili" : "storico scarso" },
    { label: "Scadenza", value: deadlineScore, max: 8, note: isClosedGrant(grant) ? "chiuso" : deadlineLabel(grant.deadline) }
  ];
}

function buildMatchActions(client, grant, ctx) {
  const actions = [];
  if (!ctx.areaHit) actions.push("Verificare domicilio operativo, sedi secondarie o partner territoriali ammessi.");
  if (ctx.capacityGap < 0) actions.push("Rafforzare capofila, rendicontazione o partenariato prima di candidare.");
  if (ctx.documentProfile?.missing?.length) actions.push(`Completare fascicolo: ${ctx.documentProfile.missing.slice(0, 3).join(", ")}.`);
  else if (!/disponibile|aggiornato|iscritto|ultim|bilancio sociale|accredit/i.test(ctx.adminReadiness)) actions.push("Caricare statuto, bilanci/rendiconti e prove di iscrizione ai registri.");
  if (isSportEntity(client.type) && client.registryRasd !== "Iscritto") actions.push("Completare il controllo RASD sul Registro nazionale prima della candidatura sportiva.");
  if (!(client.publicPartners || client.privatePartners) && grant.complexity !== "Bassa") actions.push("Costruire almeno un partner coerente con territorio e destinatari.");
  if (!ctx.sharedCriteria.length && inferGrantEvaluationCriteria(grant).length) actions.push("Confrontare i criteri del bando con progetti già finanziati o relazioni caricate.");
  if (Number.isFinite(ctx.days) && ctx.days < 8 && !isClosedGrant(grant)) actions.push("Valutare candidatura rapida solo se documenti e budget sono già pronti.");
  if (isClosedGrant(grant)) actions.push("Usare il bando come storico, non come opportunità candidabile.");
  return actions.slice(0, 4);
}

function allMatches(includeClosed = false) {
  const grants = includeClosed ? data.grants : data.grants.filter(isOpenGrant);
  return grants.flatMap(grant => data.clients.map(client => calculateMatch(client, grant))).sort(sortMatchRows);
}

function showClientMatches() {
  const client = data.clients.find(c => c.id === $("matchClient").value);
  if (!client) { toast("Seleziona un cliente"); return; }
  lastMatchRows = data.grants.map(grant => calculateMatch(client, grant)).sort(sortMatchRows);
  selectedMatch = null;
  $("matchGrant").value = "";
  $("matchTitle").textContent = `Bandi consigliati per ${client.name}`;
  renderMatchResults(lastMatchRows, "grant");
  renderMatchDetail(null);
  renderMatchPickers();
}

function showGrantMatches() {
  const grant = data.grants.find(g => g.id === $("matchGrant").value);
  if (!grant) { toast("Seleziona un bando"); return; }
  lastMatchRows = data.clients.map(client => calculateMatch(client, grant)).sort(sortMatchRows);
  selectedMatch = null;
  $("matchClient").value = "";
  $("matchTitle").textContent = `Clienti consigliati per ${grant.title}`;
  renderMatchResults(lastMatchRows, "client");
  renderMatchDetail(null);
  renderMatchPickers();
}

function selectMatchClient(id) {
  $("matchClient").value = id;
  $("matchGrant").value = "";
  showClientMatches();
}

function selectMatchGrant(id) {
  $("matchGrant").value = id;
  $("matchClient").value = "";
  showGrantMatches();
}

function renderMatchResults(rows, mode) {
  const el = $("matchResults");
  if (!rows.length) { el.className = "empty"; el.innerHTML = "Nessun risultato disponibile."; return; }
  el.className = "";
  el.innerHTML = rows.map(m => {
    const target = mode === "grant" ? m.grant : m.client;
    const sub = mode === "grant" ? `${m.grant.provider || "-"} · ${normalizedGrantStatus(m.grant)}` : `${m.client.type} · ${m.client.area || "-"} · priorità ${m.client.priority}/10`;
    const cardClass = m.score >= 75 ? "good" : m.score >= 55 ? "warn" : m.score < 35 ? "bad" : "";
    return `<div class="match-row"><div class="score-card ${cardClass}"><div class="score-lg">${m.score}</div><strong>/100</strong></div><div><h3>${esc(target.title || target.name)}</h3><p class="hint">${esc(sub)}</p>${mode === "grant" ? deadlineBadge(m.grant) : ""}<span class="inline-score">${esc(matchDecisionLabel(m))}</span><div class="reason">${m.plus.slice(0,5).map(r => `<span class="plus">${esc(r)}</span>`).join("")}${m.minus.slice(0,4).map(r => `<span class="minus">${esc(r)}</span>`).join("")}</div>${renderBreakdown(m.breakdown)}${m.actions?.length ? `<div class="advice-list">${m.actions.map(a => `<span>${esc(a)}</span>`).join("")}</div>` : ""}</div><div class="toolbar"><button class="btn" onclick="openMatchDetail('${m.client.id}','${m.grant.id}', false)">Analisi</button><button class="btn secondary" onclick="${mode === "grant" ? `openGrantFromMatch('${m.grant.id}')` : `openClientFromMatch('${m.client.id}')`}">Apri</button></div></div>`;
  }).join("");
}

function renderBreakdown(items = []) {
  return `<div class="breakdown">${items.map(item => {
    const pct = item.max ? Math.round((item.value / item.max) * 100) : 0;
    return `<div class="breakdown-item"><div class="breakdown-head"><span>${esc(item.label)}</span><span>${Math.max(0, Math.round(item.value))}/${item.max}</span></div><div class="mini-bar"><span style="width:${Math.max(0, Math.min(100, pct))}%"></span></div><span class="muted">${esc(item.note || "")}</span></div>`;
  }).join("")}</div>`;
}

function renderMatchDetail(m) {
  const el = $("matchDetail");
  if (!el) return;
  if (!m) { el.className = "empty"; el.innerHTML = "Apri una migliore occasione dalla dashboard o seleziona un risultato per vedere il perché del punteggio."; return; }
  el.className = "";
  const clientQuality = profileCompleteness(m.client);
  const grantQuality = grantDataQuality(m.grant);
  const checklist = buildApplicationChecklist(m);
  const rasdAudit = buildRasdAudit(m.client);
  const decision = matchDecisionLabel(m);
  el.innerHTML = `<div class="match-detail-hero"><div class="score-card ${m.score >= 75 ? "good" : m.score >= 55 ? "warn" : m.score < 35 ? "bad" : ""}"><div class="score-lg">${m.score}</div><strong>/100</strong></div><div><h3>${esc(m.client.name || "Cliente senza nome")} ↔ ${esc(m.grant.title || "Bando senza titolo")}</h3><p class="hint">${esc(m.grant.provider || "-")} · ${esc(normalizedGrantStatus(m.grant))}</p>${deadlineBadge(m.grant)}<span class="inline-score">${esc(decision)}</span><div class="summary-callout" style="margin-top:12px">${esc(buildMatchNarrative(m))}</div></div></div><div class="metric-grid section"><div class="fact"><strong>Decisione</strong><p>${esc(decision)}</p></div><div class="fact"><strong>Qualità cliente</strong><div class="scorebar"><span style="width:${clientQuality}%"></span></div><p>${clientQuality}% profilo compilato</p></div><div class="fact"><strong>Qualità bando</strong><div class="scorebar"><span style="width:${grantQuality.score}%"></span></div><p>${grantQuality.score}% dati bando</p></div><div class="fact"><strong>Scadenza</strong><p>${esc(deadlineLabel(m.grant.deadline))}</p></div><div class="fact"><strong>RASD</strong><p>${esc(rasdAudit.status)}</p></div></div><div class="section"><div class="section-title">Perché questo punteggio</div>${renderBreakdown(m.breakdown)}<div class="reason">${m.plus.map(r => `<span class="plus">${esc(r)}</span>`).join("")}${m.minus.map(r => `<span class="minus">${esc(r)}</span>`).join("")}</div></div><div class="section"><div class="section-title">Checklist candidatura</div><div class="task-list">${checklist.map(item => `<div class="task"><strong>${esc(item.status)} · ${esc(item.title)}</strong><p class="hint">${esc(item.detail)}</p></div>`).join("")}</div></div><div class="section"><div class="section-title">Prossimi passi consigliati</div><div class="advice-list">${buildNextSteps(m).map(step => `<span>${esc(step)}</span>`).join("")}</div></div><div class="toolbar"><button class="btn secondary" onclick="openClientFromMatch('${m.client.id}')">Apri cliente</button><button class="btn secondary" onclick="openGrantFromMatch('${m.grant.id}')">Apri bando</button></div>`;
}

function matchDecisionLabel(m) {
  if (isClosedGrant(m.grant)) return "Storico";
  const docs = clientDocumentProfile(m.client, m.grant).score;
  if (m.score >= 75 && docs >= 65) return "Candidabile";
  if (m.score >= 75) return "Da preparare";
  if (m.score >= 55) return "Da preparare";
  if (m.score >= 35) return "Da verificare";
  return "Bassa priorità";
}

function buildMatchNarrative(m) {
  const strengths = m.plus.slice(0, 3).join(", ");
  const risks = m.minus.slice(0, 3).join(", ");
  const verdict = m.score >= 75 ? "Match forte" : m.score >= 55 ? "Match interessante ma da preparare" : m.score >= 35 ? "Match debole o da verificare" : "Match non prioritario";
  const timing = isClosedGrant(m.grant) ? "Il bando è chiuso e va usato come storico." : `Tempistica: ${deadlineLabel(m.grant.deadline)}.`;
  return `${verdict}. Il punteggio nasce soprattutto da ${strengths || "pochi elementi favorevoli rilevati"}. Criticità principali: ${risks || "nessuna criticità forte emersa"}. ${timing}`;
}

function buildApplicationChecklist(m) {
  const grantDocs = inferGrantRequestedDocuments(m.grant);
  const baseDocs = grantDocs.length ? grantDocs : ["statuto", "bilancio/rendiconto", "relazione progetto", "preventivo/budget"];
  const tasks = baseDocs.map(doc => {
    const ok = clientHasDocumentSignal(m.client, doc);
    return { status: ok ? "OK" : "Manca", title: doc, detail: ok ? "Elemento trovato nel profilo o nei documenti caricati." : "Da caricare o confermare prima della candidatura." };
  });
  if (isSportEntity(m.client.type)) {
    const rasdOk = m.client.registryRasd === "Iscritto" && (m.client.rasdNumber || m.client.sportBody);
    tasks.unshift({ status: rasdOk ? "OK" : "Da verificare", title: "Controllo RASD", detail: rasdOk ? "Profilo sportivo coerente con i dati RASD inseriti." : "Aprire il Registro RASD e confermare denominazione, codice, organismo affiliante e discipline." });
  }
  if (m.grant.cofunding && !m.client.cofunding && !/0\s*%|nessun/i.test(m.grant.cofunding)) tasks.push({ status: "Da stimare", title: "Cofinanziamento", detail: `Il bando indica cofinanziamento ${m.grant.cofunding}. Serve sostenibilità economica nel profilo cliente.` });
  return tasks.slice(0, 10);
}

function clientHasDocumentSignal(client, label) {
  const hay = `${client.documents || ""} ${client.statuteStatus || ""} ${client.financialReports || ""} ${client.registryRunts || ""} ${client.registryRasd || ""} ${client.rasdNumber || ""} ${client.sportBody || ""} ${(client.documentFiles || []).map(d => `${d.name} ${d.text || ""}`).join(" ")}`.toLowerCase();
  const checks = {
    "statuto": /statuto|aggiornato riforma|cts|runts/.test(hay),
    "atto costitutivo": /atto costitutivo/.test(hay),
    "bilancio/rendiconto": /bilancio|rendiconto|rendicont/.test(hay),
    "RUNTS": /runts|iscritto/.test(hay),
    "RASD": /rasd|registro nazionale|sport e salute/.test(hay),
    "DURC": /durc/.test(hay),
    "preventivo/budget": /budget|preventivo|piano finanziario|quadro economico/.test(hay),
    "partenariati": /partner|accordo|protocollo|partenariat/.test(hay),
    "relazione progetto": /relazione|progetto|formulario|domanda/.test(hay)
  };
  return checks[label] ?? new RegExp(label.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "i").test(hay);
}

function buildNextSteps(m) {
  const steps = [...(m.actions || [])];
  if (!isClosedGrant(m.grant)) steps.unshift("Aprire la scheda ufficiale del bando e confermare scadenza, allegati e modalità di invio.");
  if (m.score >= 75) steps.push("Preparare subito una bozza candidatura e budget, perché il match è già forte.");
  else if (m.score >= 55) steps.push("Completare i documenti mancanti e rivalutare il punteggio prima di investire tempo sulla domanda.");
  return [...new Set(steps)].slice(0, 6);
}

function openMatchDetail(clientId, grantId, fromDashboard = false) {
  const client = data.clients.find(c => c.id === clientId);
  const grant = data.grants.find(g => g.id === grantId);
  if (!client || !grant) return toast("Match non trovato");
  selectedMatch = calculateMatch(client, grant);
  recordMatchAnalysis(selectedMatch, fromDashboard ? "dashboard" : "matching");
  lastMatchRows = [selectedMatch];
  $("matchClient").value = clientId;
  $("matchGrant").value = grantId;
  $("matchTitle").textContent = `Match: ${client.name} / ${grant.title}`;
  renderMatchResults(lastMatchRows, "grant");
  renderMatchDetail(selectedMatch);
  renderMatchPickers();
  if (fromDashboard) switchView("matching");
}

function recordMatchAnalysis(m, origin = "matching") {
  data.matchHistory = data.matchHistory || [];
  const documentProfile = clientDocumentProfile(m.client, m.grant);
  const entry = normalizeMatchHistory({
    clientId: m.client.id,
    clientName: m.client.name,
    grantId: m.grant.id,
    grantTitle: m.grant.title,
    grantStatus: normalizedGrantStatus(m.grant),
    deadline: m.grant.deadline,
    score: m.score,
    decision: matchDecisionLabel(m),
    documentScore: documentProfile.score,
    reasons: m.plus.slice(0, 8),
    risks: m.minus.slice(0, 8),
    actions: (m.actions || []).slice(0, 6),
    origin
  });
  const key = `${entry.clientId}|${entry.grantId}`;
  data.matchHistory = [entry, ...data.matchHistory.filter(item => `${item.clientId}|${item.grantId}` !== key)].slice(0, 500);
  persistData();
}

function sortMatchRows(a, b) {
  const statusDelta = Number(isClosedGrant(a.grant)) - Number(isClosedGrant(b.grant));
  return statusDelta || b.score - a.score;
}

window.openGrantFromMatch = id => { switchView("grants"); setGrantForm(data.grants.find(g => g.id === id)); };
window.openClientFromMatch = id => { switchView("clients"); setClientForm(data.clients.find(c => c.id === id)); };
window.selectMatchClient = selectMatchClient;
window.selectMatchGrant = selectMatchGrant;
window.openMatchDetail = openMatchDetail;

function profileCompleteness(c) {
  const keys = ["name","type","legalAddress","city","province","region","operationalSite","area","geoScope","contact","contactInfo","capacity","budget","cofunding","staff","volunteers","spaces","statuteStatus","financialReports","registryRunts","registryRasd","registryOther","rasdName","rasdNumber","sportBody","sportActivities","rasdCheckStatus","documents","activities","strengths","weaknesses","publicPartners","privatePartners","projectHistory","fundedProjects","reportingHistory","goals","notes","documentInsights","fundingInsights"];
  const filled = keys.filter(k => String(c[k] || "").trim()).length + Math.min(5, (c.tags || []).length) + Math.min(4, (c.documentFiles || []).length) + Math.min(3, (c.winningCriteria || []).length);
  return Math.min(100, Math.round((filled / (keys.length + 9)) * 100));
}

function hasCompatibleLegalType(clientType = "", eligibleTypes = []) {
  const client = legalTypeKey(clientType);
  return eligibleTypes.some(type => {
    const eligible = legalTypeKey(type);
    return client === eligible || client.includes(eligible) || eligible.includes(client);
  });
}

function legalTypeKey(value = "") {
  return String(value).toLowerCase()
    .replace(/societa/g, "società")
    .replace(/associazione sportiva dilettantistica/g, "asd")
    .replace(/società sportiva dilettantistica/g, "ssd")
    .replace(/associazione di promozione sociale/g, "aps")
    .replace(/organizzazione di volontariato/g, "odv")
    .replace(/ente del terzo settore/g, "ets")
    .replace(/ente di promozione sportiva/g, "eps")
    .replace(/federazione sportiva nazionale/g, "fsn")
    .replace(/disciplina sportiva associata/g, "dsa")
    .replace(/[^a-z0-9àèéìòù]/g, "");
}

function legalTypeDisplay(value = "") {
  const key = legalTypeKey(value);
  return LEGAL_TYPES.find(type => legalTypeKey(type) === key || legalTypeKey(type).includes(key) || key.includes(legalTypeKey(type))) || value || LEGAL_TYPES[0];
}

function clientText(c) { return `${c.name} ${c.type} ${c.legalAddress} ${c.city} ${c.province} ${c.region} ${c.operationalSite} ${c.area} ${c.status} ${c.registryRunts} ${c.registryRasd} ${c.registryOther} ${c.rasdName} ${c.rasdNumber} ${c.sportBody} ${c.sportActivities} ${c.rasdCheckStatus} ${c.statuteStatus} ${c.financialReports} ${(c.tags || []).join(" ")} ${(c.documentTags || []).join(" ")} ${(c.fundingTypes || []).join(" ")} ${(c.winningCriteria || []).join(" ")} ${c.activities} ${c.projectHistory} ${c.fundedProjects} ${c.reportingHistory} ${c.goals} ${c.notes} ${c.documentInsights || ""} ${c.fundingInsights || ""}`; }
function grantText(g) { return `${g.title} ${g.provider} ${g.area} ${normalizedGrantStatus(g)} ${(g.tags || []).join(" ")} ${g.requirements} ${g.summary} ${g.beneficiaries || ""} ${g.expenses || ""} ${g.detail || ""}`; }
function textOverlap(a = "", b = "") {
  const aw = String(a).toLowerCase().split(/[\s,;/.-]+/).filter(w => w.length > 3);
  const bw = String(b).toLowerCase().split(/[\s,;/.-]+/).filter(w => w.length > 3);
  return aw.some(w => bw.includes(w));
}
function deadlineDays(value) {
  if (!value) return Infinity;
  return Math.ceil((new Date(value + "T23:59:59") - new Date()) / 86400000);
}
function deadlineLabel(value) {
  const days = deadlineDays(value);
  if (!value) return "senza scadenza";
  if (days < 0) return `scaduto da ${Math.abs(days)} giorni`;
  if (days === 0) return "scade oggi";
  return `scade tra ${days} giorni`;
}
function deadlineBadge(g) {
  const days = deadlineDays(g.deadline);
  const cls = isClosedGrant(g) ? "deadline-closed" : Number.isFinite(days) && days <= 15 ? "deadline-soon" : g.deadline ? "deadline-open" : "deadline-neutral";
  const prefix = isClosedGrant(g) ? "Chiuso" : "Domanda";
  return `<span class="deadline-badge ${cls}">${esc(prefix)}: ${esc(deadlineLabel(g.deadline))}</span>`;
}
function normalizedGrantStatus(g) {
  if (isClosedGrant(g)) return "Chiuso";
  return g.status || "Da verificare";
}
function isClosedGrant(g) { return g.status === "Chiuso" || deadlineDays(g.deadline) < 0; }
function isOpenGrant(g) { return !isClosedGrant(g); }
function closeSortDate(g) {
  const date = g.deadline || g.updatedAt || g.discoveredAt || g.createdAt || "1970-01-01";
  return new Date(date + (String(date).includes("T") ? "" : "T12:00:00")).getTime() || 0;
}

function inferGrantEvaluationCriteria(g) {
  const text = `${g.title || ""} ${g.summary || ""} ${g.requirements || ""} ${g.detail || ""} ${g.notes || ""}`.toLowerCase();
  return matchSignals(text, [
    ["impatto sociale", /impatto|indicatori|beneficiari|risultati attesi|monitoraggio/],
    ["partenariato", /partenariat|rete|accordo|coprogettazione|co-progettazione/],
    ["cofinanziamento", /cofinanziamento|quota a carico|risorse proprie/],
    ["innovazione", /innovazion|sperimentazion|replicabil|scalabil/],
    ["capacità amministrativa", /rendicont|bilancio|esperienza|curriculum|gestione/],
    ["inclusione", /inclusion|fragil|disabil|povertà|welfare|giovani|minori/],
    ["urgenza territoriale", /perifer|aree interne|territorio|comunità|quartiere/]
  ]);
}

function inferGrantRequestedDocuments(g) {
  const text = `${g.requirements || ""} ${g.detail || ""} ${g.notes || ""}`.toLowerCase();
  return matchSignals(text, [
    ["statuto", /statuto/],
    ["atto costitutivo", /atto costitutivo/],
    ["bilancio/rendiconto", /bilancio|rendiconto|conto consuntivo|rendicontazione/],
    ["RUNTS", /runts/],
    ["RASD", /rasd|registro attività sportive|registro nazionale attività sportive/],
    ["DURC", /durc/],
    ["preventivo/budget", /preventivo|budget|piano finanziario|quadro economico/],
    ["partenariati", /lettera di partenariato|accordo|protocollo|partner/],
    ["relazione progetto", /relazione|progetto|formulario|domanda/]
  ]);
}

function exportBackup() {
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `bandi-scanner-backup-${new Date().toISOString().slice(0,10)}.json`;
  a.click();
