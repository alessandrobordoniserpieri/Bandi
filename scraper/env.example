# Scraper configuration. Copy to .env and fill in. Never commit real keys.

# Which LLM adapter to use: gemini (default) | anthropic | groq | openai.
# Switching providers = changing only this line (ADR-002).
AI_PROVIDER=gemini

# Only the key for the ACTIVE provider is required.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (each provider has a sensible default).
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o-mini

# Persistence (wired in branch 009).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
